      assign ingredients = 'Olive Oil|Neem Oil|Neem Leaves|Turmeric Extract|Soap Noodles|Glycerine|Aloe Vera|Vitamin E|Coconut Oil|Tulsi Extract'
    endif
  endif

  echo ingredients
-%}
