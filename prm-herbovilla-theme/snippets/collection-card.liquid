{%- comment -%}
  Collection Card Snippet — Icon + Text box style

  Parameters:
  - collection: Collection object (required)
{%- endcomment -%}

{%- liquid
  assign h = collection.handle
  assign icon = 'leaf'
  assign card_color = '#2D6A4F'

  if h contains 'immunity'
    assign icon = 'shield'
    assign card_color = '#2D6A4F'
  elsif h contains 'digestive' or h contains 'gut'
    assign icon = 'stomach'
    assign card_color = '#B8860B'
  elsif h contains 'respiratory' or h contains 'cough'
    assign icon = 'lungs'
    assign card_color = '#4682B4'
  elsif h contains 'joint' or h contains 'pain'
    assign icon = 'bone'
    assign card_color = '#CD5C5C'
  elsif h contains 'hair' or h contains 'skin'
    assign icon = 'sparkle'
    assign card_color = '#8B5E83'
  elsif h contains 'women'
    assign icon = 'heart'
    assign card_color = '#C9707D'
  elsif h contains 'men' and h contains 'health'
    assign icon = 'strength'
    assign card_color = '#5B7AA3'
  elsif h contains 'diabetic' or h contains 'sugar'
    assign icon = 'droplet'
    assign card_color = '#6A8D73'
  elsif h contains 'general' or h contains 'wellness'
    assign icon = 'leaf'
    assign card_color = '#40916C'
  elsif h contains 'best-seller' or h contains 'bestseller'
    assign icon = 'star'
    assign card_color = '#D4A03C'
  elsif h contains 'new-arrival'
    assign icon = 'zap'
    assign card_color = '#5D8AA8'
  elsif h contains 'child' or h contains 'kid'
    assign icon = 'baby'
    assign card_color = '#7AB8BF'
  elsif h contains 'oral' or h contains 'mouth'
    assign icon = 'smile'
    assign card_color = '#6B8E6B'
  elsif h contains 'piles'
    assign icon = 'plus-circle'
    assign card_color = '#8B6F5E'
  elsif h contains 'soap'
    assign icon = 'droplets'
    assign card_color = '#7BA4C7'
  endif
-%}

<div class="collection-card collection-card--icon" style="--card-color: {{ card_color }};">
  <div class="collection-card__icon-wrap">
    {%- case icon -%}
      {%- when 'shield' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 4L6 12v12c0 11 18 18 18 18s18-7 18-18V12L24 4z"/>
          <path d="M16 24l5 5 11-11" stroke-width="3"/>
        </svg>
      {%- when 'stomach' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6c-6 0-10 4-10 10v4c0 6 4 12 10 14"/>
          <path d="M30 6c6 0 10 4 10 10v2c0 4-2 7-5 8-2 1-5 1-6-1s-1-5 1-7c1-1 3-2 5-2"/>
          <path d="M18 34c2 2 5 4 8 4s6-2 8-4"/>
          <circle cx="18" cy="22" r="2" fill="#fff" stroke="none"/>
          <circle cx="26" cy="18" r="1.5" fill="#fff" stroke="none"/>
        </svg>
      {%- when 'lungs' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 6v20"/>
          <path d="M24 14h-4c-3 0-6 2-8 5s-3 8-2 12c1 3 3 5 6 6h4c2 0 4-2 4-4V14"/>
          <path d="M24 14h4c3 0 6 2 8 5s3 8 2 12c-1 3-3 5-6 6h-4c-2 0-4-2-4-4V14"/>
          <path d="M20 22c-2 1-3 3-3 5"/>
          <path d="M28 22c2 1 3 3 3 5"/>
        </svg>
      {%- when 'bone' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="14" cy="14" r="5"/>
          <circle cx="34" cy="34" r="5"/>
          <path d="M18 18l12 12" stroke-width="4"/>
          <circle cx="14" cy="22" r="3"/>
          <circle cx="22" cy="14" r="3"/>
          <circle cx="26" cy="34" r="3"/>
          <circle cx="34" cy="26" r="3"/>
        </svg>
      {%- when 'sparkle' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 4l3 10h10l-8 6 3 10-8-6-8 6 3-10-8-6h10z"/>
          <circle cx="10" cy="36" r="3"/>
          <circle cx="38" cy="36" r="3"/>
          <path d="M10 33v-3M38 33v-3"/>
          <path d="M24 34v8"/>
        </svg>
      {%- when 'heart' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 42s-16-9-16-20c0-5 4-9 8-9 3 0 6 2 8 5 2-3 5-5 8-5 4 0 8 4 8 9 0 11-16 20-16 20z"/>
          <path d="M18 20c-1.5 0-3 1-3 3" opacity="0.6"/>
        </svg>
      {%- when 'strength' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 20h32"/>
          <rect x="6" y="16" width="6" height="8" rx="2"/>
          <rect x="36" y="16" width="6" height="8" rx="2"/>
          <rect x="3" y="18" width="5" height="4" rx="1"/>
          <rect x="40" y="18" width="5" height="4" rx="1"/>
          <path d="M24 12v-4M24 36v4"/>
          <path d="M24 28c3 0 5-2 5-4h-10c0 2 2 4 5 4z"/>
          <circle cx="24" cy="34" r="3"/>
        </svg>
      {%- when 'droplet' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 4C24 4 10 20 10 30c0 8 6 14 14 14s14-6 14-14C38 20 24 4 24 4z"/>
          <path d="M18 30c0-4 3-8 6-12" opacity="0.5"/>
        </svg>
      {%- when 'star' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="24,4 29,18 44,18 32,28 36,42 24,33 12,42 16,28 4,18 19,18"/>
        </svg>
      {%- when 'zap' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="26,4 10,28 22,28 20,44 38,18 26,18"/>
        </svg>
      {%- when 'baby' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="24" cy="18" r="10"/>
          <path d="M14 28c0 8 4 14 10 14s10-6 10-14"/>
          <circle cx="20" cy="17" r="1.5" fill="#fff" stroke="none"/>
          <circle cx="28" cy="17" r="1.5" fill="#fff" stroke="none"/>
          <path d="M21 22c1.5 1.5 4.5 1.5 6 0"/>
        </svg>
      {%- when 'smile' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="24" cy="24" r="18"/>
          <path d="M16 28c2 4 5 6 8 6s6-2 8-6"/>
          <circle cx="18" cy="20" r="2" fill="#fff" stroke="none"/>
          <circle cx="30" cy="20" r="2" fill="#fff" stroke="none"/>
        </svg>
      {%- when 'plus-circle' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="24" cy="24" r="18"/>
          <line x1="16" y1="24" x2="32" y2="24" stroke-width="3"/>
          <line x1="24" y1="16" x2="24" y2="32" stroke-width="3"/>
        </svg>
      {%- when 'droplets' -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8c0 0-8 10-8 16 0 5 3 8 8 8s8-3 8-8c0-6-8-16-8-16z"/>
          <path d="M32 16c0 0-6 8-6 12 0 4 3 6 6 6s6-2 6-6c0-4-6-12-6-12z"/>
          <path d="M22 32c0 0-4 5-4 8 0 2 2 4 4 4s4-2 4-4c0-3-4-8-4-8z"/>
        </svg>
      {%- else -%}
        <svg viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M24 4c-2 6-8 10-14 12 2 14 8 22 14 28 6-6 12-14 14-28-6-2-12-6-14-12z"/>
          <path d="M24 16v14"/>
          <path d="M24 22h-6c2 4 6 8 6 8s4-4 6-8h-6"/>
        </svg>
    {%- endcase -%}
  </div>

  <h3 class="collection-card__title">{{ collection.title }}</h3>
  <p class="collection-card__count">
    {{ collection.products_count }}
    {% if collection.products_count == 1 %}product{% else %}products{% endif %}
  </p>

  <a href="{{ collection.url }}" class="collection-card__link" aria-label="{{ collection.title | escape }}"></a>
</div>
