  comment
    Fallback: fuzzy substring matching for products whose exact handles
    we don't hard-code. Any product whose handle contains these substrings
    will get the corresponding PDF.
  endcomment
  if pdf_file == ''
    if handle contains 'castrowin'
      assign pdf_file = 'castrowin-softgel.pdf'
    elsif handle contains 'hair-marshal' or handle contains 'hairmarshal'
      assign pdf_file = 'hair-marshal.pdf'
    elsif handle contains 'icee-rd'
      assign pdf_file = 'icee-rd-caps.pdf'
    elsif handle contains 'icee-capsule' or handle contains 'icee-caps'
      assign pdf_file = 'icee-caps.pdf'
    elsif handle contains 'icee'
      assign pdf_file = 'icee-syrup.pdf'
    elsif handle contains 'lee-capsule' or handle contains 'lee-caps'
      assign pdf_file = 'lee-caps.pdf'
    elsif handle contains 'lee'
      assign pdf_file = 'lee-syrup.pdf'
