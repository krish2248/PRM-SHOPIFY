{%- comment -%}
  Price Snippet
  
  Parameters:
  - product: Product object (required)
  - variant: Variant object (optional)
  - show_badges: Boolean (optional)
{%- endcomment -%}

{%- liquid
  if variant
    assign target = variant
  else
    assign target = product.selected_or_first_available_variant | default: product
  endif
  
  assign compare_at_price = target.compare_at_price
  assign price = target.price
  assign on_sale = false
  
  if compare_at_price > price
    assign on_sale = true
    assign savings = compare_at_price | minus: price | times: 100 | divided_by: compare_at_price
  endif
  
  assign price_varies = false
  if product.price_varies
    assign price_varies = true
  endif
-%}

<div class="price {% if on_sale %}price--on-sale{% endif %}">
  {%- if price_varies and variant == blank -%}
    <span class="price__from">From</span>
  {%- endif -%}
  
  <span class="price__regular">
    {{- price | money -}}
  </span>
  
  {%- if on_sale -%}
    <span class="price__compare">
      {{- compare_at_price | money -}}
    </span>
    
    {%- if show_badges -%}
      <span class="price__badge">Save {{ savings }}%</span>
    {%- endif -%}
  {%- endif -%}
  
  {%- if target.unit_price_measurement -%}
    <span class="price__unit">
      <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
      {{ target.unit_price | money }}
      <span aria-hidden="true">/</span>
      <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
      {%- if target.unit_price_measurement.reference_value != 1 -%}
        {{- target.unit_price_measurement.reference_value -}}
      {%- endif -%}
      {{ target.unit_price_measurement.reference_unit }}
    </span>
  {%- endif -%}
</div>
