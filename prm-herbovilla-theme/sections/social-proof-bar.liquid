{%- comment -%}
  Social Proof Bar Section
{%- endcomment -%}

<section class="social-proof">
  <div class="container">
    <div class="social-proof__grid">
      {%- for block in section.blocks -%}
        <div class="social-proof__item" {{ block.shopify_attributes }}>
          <div class="social-proof__number">{{ block.settings.number }}</div>
          <div class="social-proof__label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Proof Bar",
  "tag": "section",
  "class": "social-proof-section",
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "10,000+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy Customers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof Bar",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "10,000+",
            "label": "Happy Customers"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "44+",
            "label": "Products"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "100%",
            "label": "Natural"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "GMP",
            "label": "Certified"
          }
        }
      ]
    }
  ]
}
{% endschema %}
