{%- comment -%}
  New Arrivals Section - Large 2-Column Grid
  Shows big vertical product cards for maximum visual impact
{%- endcomment -%}

<section class="new-arrivals-large {% if section.settings.alt_background %}section--alt{% endif %}">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.label != blank -%}
        <span class="section-header__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="section-header__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>
    
    <div class="new-arrivals-grid">
      {%- liquid
        if section.settings.collection != blank
          assign products = section.settings.collection.products
        else
          assign products = collections['all'].products
        endif
      -%}
      
      {%- for product in products limit: section.settings.products_count -%}
        <div class="new-arrival-card">
          <a href="{{ product.url }}" class="new-arrival-card__link">
            <!-- Image -->
            <div class="new-arrival-card__image">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                          {{ product.featured_image | image_url: width: 600 }} 600w,
                          {{ product.featured_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 768px) 100vw, 50vw"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              
              <!-- Badges -->
              <div class="new-arrival-card__badges">
                {%- if product.compare_at_price > product.price -%}
                  {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                  <span class="badge badge--sale">-{{ discount }}%</span>
                {%- endif -%}
                <span class="badge badge--new">New</span>
              </div>
              
              <!-- Quick Add -->
              {%- if product.available -%}
                <button 
                  type="button" 
                  class="new-arrival-card__quick-add"
                  data-add-to-cart 
                  data-variant-id="{{ product.first_available_variant.id }}"
                  aria-label="Add to cart"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                  </svg>
                  <span>Add to Cart</span>
                </button>
              {%- endif -%}
            </div>
            
            <!-- Content -->
            <div class="new-arrival-card__content">
              {%- if section.settings.show_vendor and product.vendor != blank -%}
                <p class="new-arrival-card__vendor">{{ product.vendor }}</p>
              {%- endif -%}
              
              <h3 class="new-arrival-card__title">{{ product.title }}</h3>
              
              {%- if product.description != blank -%}
                <p class="new-arrival-card__description">
                  {{ product.description | strip_html | truncate: 100 }}
                </p>
              {%- endif -%}
              
              <div class="new-arrival-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="new-arrival-card__price-compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                <span class="new-arrival-card__price-current">{{ product.price | money }}</span>
              </div>
            </div>
          </a>
        </div>
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="new-arrival-card">
            <div class="new-arrival-card__link">
              <div class="new-arrival-card__image">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                <div class="new-arrival-card__badges">
                  <span class="badge badge--new">New</span>
                </div>
              </div>
              <div class="new-arrival-card__content">
                <p class="new-arrival-card__vendor">PRM HerboVilla</p>
                <h3 class="new-arrival-card__title">Sample Product {{ i }}</h3>
                <p class="new-arrival-card__description">Natural Ayurvedic product for your health and wellness needs.</p>
                <div class="new-arrival-card__price">
                  <span class="new-arrival-card__price-current">₹299</span>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
    
    {%- if section.settings.button_text != blank -%}
      <div class="text-center mt-2xl">
        <a href="{{ section.settings.button_link | default: section.settings.collection.url | default: routes.all_products_collection_url }}" class="btn btn--secondary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .new-arrivals-large {
    padding: 80px 0;
    background: #FDF8F0;
  }
  
  .new-arrivals-large.section--alt {
    background: #fff;
  }
  
  .new-arrivals-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
    margin-top: 50px;
  }
  
  /* Card */
  .new-arrival-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transition: all 0.4s ease;
  }
  
  .new-arrival-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
  }
  
  .new-arrival-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  
  /* Image */
  .new-arrival-card__image {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f5f5f5;
  }
  
  .new-arrival-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .new-arrival-card:hover .new-arrival-card__image img {
    transform: scale(1.05);
  }
  
  .new-arrival-card__image .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: #ddd;
  }
  
  /* Badges */
  .new-arrival-card__badges {
    position: absolute;
    top: 16px;
    left: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .new-arrival-card__badges .badge {
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .new-arrival-card__badges .badge--new {
    background: #2D6A4F;
    color: #fff;
  }
  
  .new-arrival-card__badges .badge--sale {
    background: #D32F2F;
    color: #fff;
  }
  
  /* Quick Add Button */
  .new-arrival-card__quick-add {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    display: flex;
    align-items: center;
    gap: 10px;
    background: #2D6A4F;
    color: #fff;
    border: none;
    padding: 14px 28px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    opacity: 0;
    transition: all 0.3s ease;
    white-space: nowrap;
  }
  
  .new-arrival-card__quick-add svg {
    width: 18px;
    height: 18px;
  }
  
  .new-arrival-card:hover .new-arrival-card__quick-add {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  
  .new-arrival-card__quick-add:hover {
    background: #1B5E20;
  }
  
  /* Content */
  .new-arrival-card__content {
    padding: 28px;
  }
  
  .new-arrival-card__vendor {
    font-size: 13px;
    color: #888;
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .new-arrival-card__title {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 12px 0;
    line-height: 1.3;
  }
  
  .new-arrival-card__description {
    font-size: 15px;
    color: #666;
    line-height: 1.6;
    margin: 0 0 16px 0;
  }
  
  .new-arrival-card__price {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .new-arrival-card__price-current {
    font-size: 24px;
    font-weight: 700;
    color: #2D6A4F;
  }
  
  .new-arrival-card__price-compare {
    font-size: 18px;
    color: #999;
    text-decoration: line-through;
  }
  
  /* Responsive */
  @media (max-width: 900px) {
    .new-arrivals-grid {
      gap: 24px;
    }
    
    .new-arrival-card__content {
      padding: 20px;
    }
    
    .new-arrival-card__title {
      font-size: 20px;
    }
    
    .new-arrival-card__quick-add {
      padding: 12px 20px;
      font-size: 13px;
    }
  }
  
  @media (max-width: 640px) {
    .new-arrivals-large {
      padding: 50px 0;
    }
    
    .new-arrivals-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 30px;
    }
    
    .new-arrival-card__image {
      aspect-ratio: 4/5;
    }
    
    .new-arrival-card__quick-add {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
      bottom: 16px;
      padding: 12px 24px;
    }
    
    .new-arrival-card__title {
      font-size: 18px;
    }
    
    .new-arrival-card__price-current {
      font-size: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "New Arrivals Large",
  "tag": "section",
  "class": "new-arrivals-large-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "alt_background",
      "label": "Use Alternative Background",
      "default": false
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Just Launched"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover our latest Ayurvedic formulations crafted with ancient wisdom and modern science."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of Products",
      "min": 2,
      "max": 8,
      "step": 2,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show Vendor",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All New Products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals Large"
    }
  ]
}
{% endschema %}
