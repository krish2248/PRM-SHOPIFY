{%- comment -%}
  Hero Section - Two Column Layout
{%- endcomment -%}

{%- style -%}
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(253, 248, 240, 0.95) 0%, rgba(253, 248, 240, 0.8) 50%, rgba(253, 248, 240, 0.6) 100%);
    z-index: 1;
  }
  .hero .container {
    position: relative;
    z-index: 2;
    width: 100%;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .hero__label {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(45, 106, 79, 0.1);
    border: 1px solid rgba(45, 106, 79, 0.2);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }
  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: 25px;
  }
  .hero__text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: 35px;
    max-width: 540px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 40px;
  }
  .hero__features {
    display: flex;
    flex-wrap: wrap;
    gap: 25px;
  }
  .hero__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
    color: var(--color-text);
    font-weight: 500;
  }
  .hero__feature-icon {
    width: 22px;
    height: 22px;
    color: var(--color-primary);
    background: rgba(45, 106, 79, 0.1);
    border-radius: 50%;
    padding: 4px;
  }
  /* Right Side - Product Showcase */
  .hero__right {
    position: relative;
  }
  .hero__product-showcase {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero__product-main {
    position: relative;
    z-index: 2;
  }
  .hero__product-image {
    width: 100%;
    max-width: 400px;
    height: auto;
    filter: drop-shadow(0 30px 60px rgba(45, 106, 79, 0.2));
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  .hero__floating-badge {
    position: absolute;
    background: #fff;
    border-radius: 15px;
    padding: 15px 20px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
    animation: floatBadge 4s ease-in-out infinite;
  }
  .hero__floating-badge--1 {
    top: 10%;
    right: -10%;
    animation-delay: 0s;
  }
  .hero__floating-badge--2 {
    bottom: 20%;
    left: -5%;
    animation-delay: 1s;
  }
  .hero__floating-badge--3 {
    bottom: 5%;
    right: 5%;
    animation-delay: 2s;
  }
  @keyframes floatBadge {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  .hero__badge-icon {
    width: 40px;
    height: 40px;
    background: rgba(45, 106, 79, 0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }
  .hero__badge-icon svg {
    width: 22px;
    height: 22px;
    color: var(--color-primary);
  }
  .hero__badge-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .hero__badge-subtext {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }
  /* Stats Row */
  .hero__stats {
    display: flex;
    gap: 40px;
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid rgba(45, 106, 79, 0.15);
  }
  .hero__stat {
    text-align: center;
  }
  .hero__stat-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }
  .hero__stat-label {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-top: 5px;
  }
  /* No product image fallback */
  .hero__features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }
  .hero__feature-card {
    background: #fff;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .hero__feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
  }
  .hero__feature-card-icon {
    width: 50px;
    height: 50px;
    background: rgba(45, 106, 79, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
  }
  .hero__feature-card-icon svg {
    width: 26px;
    height: 26px;
    color: var(--color-primary);
  }
  .hero__feature-card h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .hero__feature-card p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }
  /* Responsive */
  @media (max-width: 992px) {
    .hero {
      min-height: auto;
      padding: 56px 0 48px;
    }
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    /* Mobile: Ancient Wisdom content first, feature cards / product after */
    .hero__content { order: 1; text-align: center; }
    .hero__right   { order: 2; }
    .hero__text    { margin-left: auto; margin-right: auto; }
    .hero__actions,
    .hero__features { justify-content: center; }
    .hero__product-image { max-width: 280px; }
    .hero__floating-badge { display: none; }
    .hero__stats { justify-content: center; }
  }
  @media (max-width: 576px) {
    .hero { padding: 40px 0 36px; }
    .hero__title { font-size: clamp(1.6rem, 7vw, 2.1rem); }
    .hero__text  { font-size: 0.95rem; }
    .hero__actions { flex-direction: column; gap: 12px; }
    .hero__actions .btn { width: 100%; justify-content: center; }
    .hero__features { flex-direction: column; gap: 12px; }
    .hero__stats { flex-wrap: wrap; gap: 20px; justify-content: center; }
    .hero__features-grid { grid-template-columns: 1fr; gap: 16px; }
    .hero__feature-card { padding: 22px 20px; }
  }

  /* Tiny phones (≤375px) — iPhone SE / small Androids */
  @media (max-width: 375px) {
    .hero { padding: 32px 0 28px; }
    .hero__title { font-size: 1.45rem; line-height: 1.2; }
    .hero__text  { font-size: 0.88rem; }
    .hero__label { font-size: 0.7rem; padding: 6px 14px; }
    .hero__stat-number { font-size: 1.5rem; }
    .hero__stat-label  { font-size: 0.72rem; }
  }

  /* Landscape phones — keep hero from dominating the viewport */
  @media (max-width: 900px) and (orientation: landscape) and (max-height: 500px) {
    .hero { padding: 28px 0 24px; min-height: auto; }
    .hero__grid { grid-template-columns: 1.2fr 0.8fr; gap: 24px; }
    .hero__content { order: 0; text-align: left; }
    .hero__right   { order: 0; }
    .hero__text    { margin-left: 0; }
    .hero__actions,
    .hero__features { justify-content: flex-start; flex-direction: row; }
    .hero__actions .btn { width: auto; }
    .hero__product-image { max-width: 180px; }
  }

  /* Respect users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__product-image,
    .hero__floating-badge { animation: none; }
  }

  /* ============================================
     QUALIFICATIONS STRIP — pinned at hero bottom
     ============================================ */
  .hero { padding-bottom: 150px; }
  .hero__quali-strip {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 28px;
    z-index: 3;
    background: #ffffff;
    border-top: 1px solid #eef0ea;
    border-bottom: 1px solid #eef0ea;
    padding: 18px 0;
    box-shadow: 0 -8px 24px rgba(45, 106, 79, 0.05);
  }
  .hero__quali-track {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 13px;
    align-items: stretch;
  }
  .hero__quali-chip {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 12px 14px;
    background: #fdfdfb;
    border: 1px solid #e8ebe0;
    border-radius: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .hero__quali-chip:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(45, 106, 79, 0.10);
    border-color: rgba(45, 106, 79, 0.25);
  }
  .hero__quali-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border-radius: 8px;
    background: rgba(45, 106, 79, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }
  .hero__quali-icon svg {
    width: 19px;
    height: 19px;
  }
  .hero__quali-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .hero__quali-title {
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    letter-spacing: 0.2px;
  }
  .hero__quali-sub {
    font-size: 0.75rem;
    color: var(--color-text-light);
    line-height: 1.25;
    margin-top: 2px;
  }
  @media (max-width: 1100px) {
    .hero__quali-track { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 992px) {
    .hero { padding-bottom: 24px; }
    .hero__quali-strip {
      position: static;
      margin-top: 40px;
      padding: 18px 0;
      box-shadow: none;
    }
  }
  @media (max-width: 640px) {
    .hero__quali-strip { padding: 14px 0; }
    .hero__quali-track {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .hero__quali-chip { padding: 10px 12px; gap: 9px; }
    .hero__quali-icon { width: 32px; height: 32px; }
    .hero__quali-icon svg { width: 16px; height: 16px; }
    .hero__quali-title { font-size: 0.78rem; }
    .hero__quali-sub { font-size: 0.68rem; }
  }
{%- endstyle -%}

<section class="hero section">
  {%- if section.settings.image != blank -%}
    <div class="hero__background">
      <img 
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w,
                {{ section.settings.image | image_url: width: 1600 }} 1600w,
                {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {%- endif -%}
  
  <div class="hero__overlay"></div>
  
  <div class="container">
    <div class="hero__grid">
      <!-- Left Side - Content -->
      <div class="hero__content" data-animate>
        {%- if section.settings.label != blank -%}
          <span class="hero__label">{{ section.settings.label }}</span>
        {%- endif -%}
        
        <h1 class="hero__title">
          {{ section.settings.title | newline_to_br }}
        </h1>
        
        {%- if section.settings.text != blank -%}
          <p class="hero__text">{{ section.settings.text }}</p>
        {%- endif -%}
        
        <div class="hero__actions">
          {%- if section.settings.button_text != blank -%}
            <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--lg">
              {{ section.settings.button_text }}
            </a>
          {%- endif -%}
          
          {%- if section.settings.button_text_2 != blank -%}
            <a href="{{ section.settings.button_link_2 }}" class="btn btn--secondary btn--lg">
              {{ section.settings.button_text_2 }}
            </a>
          {%- endif -%}
        </div>
        
        {%- if section.settings.show_features -%}
          <div class="hero__features">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <div class="hero__feature" {{ block.shopify_attributes }}>
                  <svg class="hero__feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  <span>{{ block.settings.text }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
        
        {%- if section.settings.show_stats -%}
          <div class="hero__stats">
            <div class="hero__stat">
              <div class="hero__stat-number">{{ section.settings.stat_1_number | default: '50+' }}</div>
              <div class="hero__stat-label">{{ section.settings.stat_1_label | default: 'Products' }}</div>
            </div>
            <div class="hero__stat">
              <div class="hero__stat-number">{{ section.settings.stat_2_number | default: '10K+' }}</div>
              <div class="hero__stat-label">{{ section.settings.stat_2_label | default: 'Happy Customers' }}</div>
            </div>
            <div class="hero__stat">
              <div class="hero__stat-number">{{ section.settings.stat_3_number | default: '25+' }}</div>
              <div class="hero__stat-label">{{ section.settings.stat_3_label | default: 'Years Experience' }}</div>
            </div>
          </div>
        {%- endif -%}
      </div>
      
      <!-- Right Side - Product Showcase or Feature Cards -->
      <div class="hero__right" data-animate>
        {%- if section.settings.product_image != blank -%}
          <div class="hero__product-showcase">
            <div class="hero__product-main">
              <img 
                src="{{ section.settings.product_image | image_url: width: 800 }}"
                alt="{{ section.settings.product_image.alt | default: 'Featured Product' }}"
                class="hero__product-image"
                loading="eager"
              >
            </div>
            
            <!-- Floating Badges -->
            <div class="hero__floating-badge hero__floating-badge--1">
              <div class="hero__badge-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              </div>
              <div class="hero__badge-text">100% Natural</div>
              <div class="hero__badge-subtext">No Chemicals</div>
            </div>
            
            <div class="hero__floating-badge hero__floating-badge--2">
              <div class="hero__badge-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              </div>
              <div class="hero__badge-text">GMP Certified</div>
              <div class="hero__badge-subtext">Quality Assured</div>
            </div>
            
            <div class="hero__floating-badge hero__floating-badge--3">
              <div class="hero__badge-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                </svg>
              </div>
              <div class="hero__badge-text">Ayurvedic</div>
              <div class="hero__badge-subtext">Ancient Wisdom</div>
            </div>
          </div>
        {%- else -%}
          <!-- Feature Cards when no product image -->
          <div class="hero__features-grid">
            <div class="hero__feature-card">
              <div class="hero__feature-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                </svg>
              </div>
              <h3>Pure Herbal</h3>
              <p>All natural ingredients sourced from the Himalayas</p>
            </div>
            <div class="hero__feature-card">
              <div class="hero__feature-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
              </div>
              <h3>Clinically Tested</h3>
              <p>Formulas backed by scientific research</p>
            </div>
            <div class="hero__feature-card">
              <div class="hero__feature-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              </div>
              <h3>No Side Effects</h3>
              <p>Safe for long-term wellness support</p>
            </div>
            <div class="hero__feature-card">
              <div class="hero__feature-card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
              </div>
              <h3>Expert Formulated</h3>
              <p>Created by Ayurvedic practitioners</p>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if section.settings.show_quali_strip -%}
    <div class="hero__quali-strip" data-animate>
      <div class="container">
        <div class="hero__quali-track">
          <div class="hero__quali-chip">
            <div class="hero__quali-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/>
              </svg>
            </div>
            <div class="hero__quali-text">
              <span class="hero__quali-title">{{ section.settings.q1_title | default: 'WHO-GMP' }}</span>
              <span class="hero__quali-sub">{{ section.settings.q1_sub | default: 'Certified facility' }}</span>
            </div>
          </div>

          <div class="hero__quali-chip">
            <div class="hero__quali-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <div class="hero__quali-text">
              <span class="hero__quali-title">{{ section.settings.q2_title | default: 'Global GMP' }}</span>
              <span class="hero__quali-sub">{{ section.settings.q2_sub | default: 'Schedule T/M' }}</span>
            </div>
          </div>

          <div class="hero__quali-chip">
            <div class="hero__quali-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <div class="hero__quali-text">
              <span class="hero__quali-title">{{ section.settings.q3_title | default: 'ISO 9001:2015' }}</span>
              <span class="hero__quali-sub">{{ section.settings.q3_sub | default: 'Quality systems' }}</span>
            </div>
          </div>

          <div class="hero__quali-chip">
            <div class="hero__quali-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
              </svg>
            </div>
            <div class="hero__quali-text">
              <span class="hero__quali-title">{{ section.settings.q4_title | default: 'AYUSH' }}</span>
              <span class="hero__quali-sub">{{ section.settings.q4_sub | default: 'Govt. of India' }}</span>
            </div>
          </div>

          <div class="hero__quali-chip">
            <div class="hero__quali-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <div class="hero__quali-text">
              <span class="hero__quali-title">{{ section.settings.q5_title | default: 'FSSAI' }}</span>
              <span class="hero__quali-sub">{{ section.settings.q5_sub | default: 'Food safety' }}</span>
            </div>
          </div>

          <div class="hero__quali-chip">
            <div class="hero__quali-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
            <div class="hero__quali-text">
              <span class="hero__quali-title">{{ section.settings.q6_title | default: 'FDA' }}</span>
              <span class="hero__quali-sub">{{ section.settings.q6_sub | default: 'Regulatory approved' }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section",
  "settings": [
