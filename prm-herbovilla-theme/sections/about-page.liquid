  .showcase-tile__placeholder--building span { color: #fff; }
  .showcase-tile__placeholder--green { background: linear-gradient(145deg, #2D6A4F 0%, #40916C 100%); color: #fff; }
  .showcase-tile__placeholder--green span { color: #fff; }
  .showcase-tile__placeholder--amber { background: linear-gradient(145deg, #8B5E3C 0%, #B07A4F 100%); color: #fff; }
  .showcase-tile__placeholder--amber span { color: #fff; }
  .showcase-tile__placeholder--lab { background: linear-gradient(145deg, #FDF8F0 0%, #E8DEC8 100%); color: #1B4332; }
  .showcase-tile__placeholder--herbs { background: linear-gradient(145deg, #D8F3DC 0%, #B7E4C7 100%); color: #1B4332; }
  .showcase-tile__placeholder--product { background: linear-gradient(145deg, #1B4332 0%, #2D6A4F 100%); color: #fff; }
  .showcase-tile__placeholder--product span { color: #fff; }

  .showcase-stat {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 28px 18px;
    text-align: center;
  }
  .showcase-stat--green { background: linear-gradient(145deg, #2D6A4F 0%, #1B4332 100%); color: #fff; }
  .showcase-stat--amber { background: linear-gradient(145deg, #8B5E3C 0%, #6E4731 100%); color: #fff; }
  .showcase-stat__icon svg { width: 44px; height: 44px; opacity: 0.85; }
  .showcase-stat__num {
