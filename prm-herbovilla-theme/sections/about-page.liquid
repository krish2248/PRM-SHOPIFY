    max-width: 1180px;
    margin: 0 auto;
  }
  .about-value {
    background: #fff;
    padding: 22px 20px;
    border-radius: 14px;
    border: 1px solid #EFE7D9;
    text-align: left;
  }
  .about-value__icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
