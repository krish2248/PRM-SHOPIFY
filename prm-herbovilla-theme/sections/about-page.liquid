            <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M20 34a11 11 0 0 1-2-22c9-2 12-3 15-7 2 3 3 7 3 12 0 9-8 17-16 17Z"/>
              <path d="M4 36c0-5 3-9 8-10 4-1 8-3 9-5"/>
