    height: 76px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }

  .about-leader__name {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: #1B4332;
    margin: 0 0 4px;
  }

  .about-leader__role {
    color: #8B5E3C;
    font-size: 0.88rem;
    font-weight: 600;
    margin: 0 0 14px;
  }

  .about-leader__bio {
    color: #555;
    font-size: 0.93rem;
    line-height: 1.65;
    margin: 0;
  }

  /* Manufacturing */
  .about-manufacturing__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .about-manufacturing__label {
    display: inline-block;
    font-size: 0.85rem;
    color: #2D6A4F;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .about-manufacturing__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    color: #1a1a1a;
    margin-bottom: 1.3rem;
    line-height: 1.25;
  }

  .about-manufacturing__text {
    color: #555;
    line-height: 1.85;
    margin-bottom: 1.6rem;
  }

  .about-manufacturing__text p + p {
    margin-top: 0.9rem;
  }

  .about-manufacturing__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 4px 20px;
  }

  .about-manufacturing__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    color: #333;
    font-size: 0.92rem;
  }

  .about-manufacturing__feature svg {
    width: 18px;
    height: 18px;
    color: #2D6A4F;
    flex-shrink: 0;
  }

  .about-manufacturing__image img,
  .about-manufacturing__placeholder {
    width: 100%;
    border-radius: 16px;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .about-manufacturing__placeholder {
    background: linear-gradient(135deg, #E8F5E9 0%, #B7E4C7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
  }

  .about-manufacturing__placeholder svg {
    width: 120px;
    height: 120px;
    color: #1B4332;
    opacity: 0.55;
  }

  .about-manufacturing__placeholder span {
    font-size: 0.9rem;
    color: #1B4332;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Certifications */
  .about-certs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 22px;
    margin-top: 40px;
  }

  .about-cert {
    background: #fff;
    border: 1px solid #EFE7D9;
    border-radius: 14px;
    padding: 26px 22px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .about-cert:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(27, 67, 50, 0.08);
  }

  .about-cert__icon {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
    letter-spacing: 0.04em;
  }

  .about-cert__icon--small {
    font-size: 0.85rem;
  }

  .about-cert h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #1B4332;
    margin: 0 0 8px;
  }

  .about-cert p {
    color: #555;
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .about-cta {
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
  }

  .about-cta__content {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .about-cta__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.6vw, 2.3rem);
    margin-bottom: 0.9rem;
    color: #fff;
  }

  .about-cta__text {
    font-size: 1.02rem;
    opacity: 0.92;
    margin-bottom: 1.6rem;
    line-height: 1.7;
  }

  .about-cta__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .about-cta .btn--primary {
    background: #fff;
    color: #2D6A4F;
    border-color: #fff;
  }

  .about-cta .btn--primary:hover {
    background: #FDF8F0;
  }

  .about-cta .btn--outline {
    border-color: #fff;
    color: #fff;
    background: transparent;
  }

  .about-cta .btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Tablet & mobile */
  @media (max-width: 900px) {
    .about-parent__grid,
    .about-mission__grid,
    .about-manufacturing__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .about-mission__image,
    .about-manufacturing__image {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .about-timeline::before {
      left: 30px;
    }

    .about-timeline__item {
      grid-template-columns: 1fr;
      padding-left: 60px;
    }

    .about-timeline__item::before {
      left: 24px;
      top: 24px;
    }

    .about-timeline__item--highlight::before {
      left: 22px;
    }

    .about-timeline__year {
      text-align: left;
      margin-bottom: 6px;
    }

    .about-timeline__body {
      grid-column: 1;
    }

    .about-hero__badge {
      font-size: 0.7rem;
      padding: 5px 10px;
    }

    .about-parent__card {
      padding: 22px;
    }

    .about-cta__buttons .btn {
      flex: 1 1 100%;
      justify-content: center;
    }
  }
</style>

