  .faq-item[open] {
    border-color: #2D6A4F;
    box-shadow: 0 14px 34px rgba(27, 67, 50, 0.08);
  }

  .faq-item__q {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
