{%- comment -%}
  About Us Page Template
  Showcases company history, values, and team
{%- endcomment -%}

<div class="about-page">
  {%- comment -%} Hero Section {%- endcomment -%}
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__content">
        <span class="about-hero__label">{{ section.settings.hero_label | default: 'Our Story' }}</span>
        <h1 class="about-hero__title">{{ section.settings.hero_title | default: 'Rooted in Tradition, Driven by Wellness' }}</h1>
        <p class="about-hero__text">{{ section.settings.hero_text | default: 'Since our founding, PRM HerboVilla has been committed to bringing authentic Ayurvedic wellness solutions to modern families. From the fertile soils of Gujarat to the wellness shelves of thousands of Indian homes, we carry forward a 5,000-year-old healing tradition with uncompromising integrity, scientific rigor, and a deep love for the plants that have nourished generations.' }}</p>
      </div>
    </div>
  </section>

  {%- comment -%} Stats Strip {%- endcomment -%}
  <section class="about-stats">
    <div class="container">
      <div class="about-stats__grid">
        <div class="about-stats__item">
          <div class="about-stats__num">{{ section.settings.stat_1_num | default: '15+' }}</div>
          <div class="about-stats__label">{{ section.settings.stat_1_label | default: 'Years of Experience' }}</div>
        </div>
        <div class="about-stats__item">
          <div class="about-stats__num">{{ section.settings.stat_2_num | default: '44+' }}</div>
          <div class="about-stats__label">{{ section.settings.stat_2_label | default: 'Authentic Products' }}</div>
        </div>
        <div class="about-stats__item">
          <div class="about-stats__num">{{ section.settings.stat_3_num | default: '50,000+' }}</div>
          <div class="about-stats__label">{{ section.settings.stat_3_label | default: 'Happy Customers' }}</div>
        </div>
        <div class="about-stats__item">
          <div class="about-stats__num">{{ section.settings.stat_4_num | default: '100%' }}</div>
          <div class="about-stats__label">{{ section.settings.stat_4_label | default: 'Natural Ingredients' }}</div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Mission Section {%- endcomment -%}
  <section class="about-mission section">
    <div class="container">
      <div class="about-mission__grid">
        <div class="about-mission__image">
          {%- if section.settings.mission_image != blank -%}
            <img src="{{ section.settings.mission_image | image_url: width: 600 }}" 
                 alt="{{ section.settings.mission_image.alt | default: 'Our Mission' }}"
                 loading="lazy">
          {%- else -%}
            <div class="about-mission__placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
          {%- endif -%}
        </div>
        <div class="about-mission__content">
          <span class="about-mission__label">{{ section.settings.mission_label | default: 'Our Mission' }}</span>
          <h2 class="about-mission__title">{{ section.settings.mission_title | default: 'Bringing Ayurveda to Every Home' }}</h2>
          <div class="about-mission__text">
            {{ section.settings.mission_text | default: '<p>At PRM HerboVilla, we believe that nature holds the key to optimal health. Our mission is to make authentic Ayurvedic remedies accessible to everyone, without compromising on quality or purity. We work hand-in-hand with local herb growers, traditional Vaidyas, and modern formulation scientists to bring you remedies that honour ancient wisdom while standing up to today\'s rigorous safety standards.</p><p>Every product we create is the result of extensive research, time-tested traditional knowledge, and modern manufacturing practices that ensure safety, potency, and consistency in every single batch. Whether it is a digestive tonic for your morning routine or a nourishing tablet for long-term vitality, we craft each formulation as if it were going to our own family.</p><p>Beyond products, our mission is to rebuild a culture of preventive, plant-based wellness in every Indian household — one trusted bottle at a time.</p>' }}
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Vision Section {%- endcomment -%}
  <section class="about-vision section section--alt">
    <div class="container">
      <div class="about-vision__inner">
        <span class="about-vision__label">{{ section.settings.vision_label | default: 'Our Vision' }}</span>
        <h2 class="about-vision__title">{{ section.settings.vision_title | default: 'A Healthier India, the Ayurvedic Way' }}</h2>
        <div class="about-vision__text rte">
          {{ section.settings.vision_text | default: '<p>We envision a future where every Indian family begins their day with the wisdom of Ayurveda — where preventive care is a way of life, where chemicals give way to chlorophyll, and where wellness is not a luxury but a daily right. PRM HerboVilla is committed to building that future, one authentic herbal solution at a time.</p><p>Through trusted formulations, transparent sourcing, and continuous education, we want to make Ayurveda the first choice — not the last resort — for the modern Indian household.</p>' }}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Values Section {%- endcomment -%}
  <section class="about-values section section--alt">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-header__label">{{ section.settings.values_label | default: 'What We Stand For' }}</span>
        <h2 class="section-header__title">{{ section.settings.values_title | default: 'Our Core Values' }}</h2>
      </div>
      
      <div class="about-values__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'value' -%}
            <div class="value-card" {{ block.shopify_attributes }}>
              <div class="value-card__icon">
                {%- case block.settings.icon -%}
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
                      <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
                    </svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      <path d="m9 12 2 2 4-4"/>
                    </svg>
                  {%- when 'heart' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                    </svg>
                  {%- when 'users' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                      <circle cx="9" cy="7" r="4"/>
                      <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                  {%- when 'award' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <circle cx="12" cy="8" r="6"/>
                      <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                {%- endcase -%}
              </div>
              <h3 class="value-card__title">{{ block.settings.title }}</h3>
              <p class="value-card__text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} Story Timeline {%- endcomment -%}
  <section class="about-story section">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-header__label">{{ section.settings.story_label | default: 'Our Journey' }}</span>
        <h2 class="section-header__title">{{ section.settings.story_title | default: 'The PRM HerboVilla Story' }}</h2>
      </div>
      
      <div class="about-story__content">
        <div class="about-story__text rte">
          {{ section.settings.story_content | default: '<p>Founded in the heart of Gujarat, PRM HerboVilla began with a simple vision: to bring the healing power of Ayurveda to every household. What started as a small manufacturing unit has grown into a trusted name in herbal wellness.</p><p>Our journey has been guided by the principles of Ayurveda — balance, purity, and harmony with nature. Every formulation we create honors centuries of traditional knowledge while meeting modern standards of quality and safety.</p><p>Today, we are proud to serve thousands of customers across India, helping them achieve their health goals naturally. Our state-of-the-art facility in Bhavnagar combines traditional Ayurvedic practices with modern manufacturing excellence.</p>' }}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Manufacturing Section {%- endcomment -%}
  <section class="about-manufacturing section section--alt">
    <div class="container">
      <div class="about-manufacturing__grid">
        <div class="about-manufacturing__content">
          <span class="about-manufacturing__label">{{ section.settings.mfg_label | default: 'Quality Assurance' }}</span>
          <h2 class="about-manufacturing__title">{{ section.settings.mfg_title | default: 'Our Manufacturing Excellence' }}</h2>
          <div class="about-manufacturing__text rte">
            {{ section.settings.mfg_text | default: '<p>Our manufacturing facility is located in the Gujarat Industrial Development Corporation area in Bhavnagar. We follow strict GMP (Good Manufacturing Practices) guidelines to ensure every product meets the highest quality standards.</p>' }}
          </div>
          
          <ul class="about-manufacturing__features">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <li class="about-manufacturing__feature" {{ block.shopify_attributes }}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
        <div class="about-manufacturing__image">
          {%- if section.settings.mfg_image != blank -%}
            <img src="{{ section.settings.mfg_image | image_url: width: 600 }}" 
                 alt="{{ section.settings.mfg_image.alt | default: 'Our Manufacturing Facility' }}"
                 loading="lazy">
          {%- else -%}
            <div class="about-manufacturing__placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>
                <path d="M17 18h1M12 18h1M7 18h1"/>
              </svg>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Why Choose Us {%- endcomment -%}
  <section class="about-why section">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-header__label">{{ section.settings.why_label | default: 'Why PRM HerboVilla' }}</span>
        <h2 class="section-header__title">{{ section.settings.why_title | default: 'Six Reasons Families Trust Us' }}</h2>
      </div>

      <div class="about-why__grid">
        <div class="about-why__card">
          <div class="about-why__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3>Single-Origin Herbs</h3>
          <p>Each batch is traced to its farm, harvested at peak potency by Indian growers we know by name.</p>
        </div>
        <div class="about-why__card">
          <div class="about-why__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3>Triple-Tested Safety</h3>
          <p>Every raw material, in-process batch, and finished bottle passes three independent quality checkpoints.</p>
        </div>
        <div class="about-why__card">
          <div class="about-why__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 5-5"/></svg>
          </div>
          <h3>Clinically Aware Formulations</h3>
          <p>Classical Ayurvedic recipes refined through modern pharmacology so dosages are reliable and effective.</p>
        </div>
        <div class="about-why__card">
          <div class="about-why__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Fresh-Batch Promise</h3>
          <p>Nothing sits on a warehouse shelf. We manufacture in small, frequent runs so you receive truly fresh medicine.</p>
        </div>
        <div class="about-why__card">
          <div class="about-why__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <h3>Family-First Care</h3>
          <p>From mothers to grandparents, every formulation is designed to be gentle enough for daily household wellness.</p>
        </div>
        <div class="about-why__card">
          <div class="about-why__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          </div>
          <h3>AYUSH-Recognised</h3>
          <p>Licensed and recognised by the Ministry of AYUSH, with full GMP and ISO compliance documented for every product.</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Milestones / Timeline {%- endcomment -%}
  <section class="about-timeline section section--alt">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-header__label">{{ section.settings.timeline_label | default: 'Milestones' }}</span>
        <h2 class="section-header__title">{{ section.settings.timeline_title | default: 'A Decade and a Half of Wellness' }}</h2>
      </div>
      <div class="about-timeline__list">
        <div class="about-timeline__item">
          <div class="about-timeline__year">2009</div>
          <div class="about-timeline__body">
            <h4>The Beginning</h4>
            <p>PRM Pharmaceuticals is founded in Bhavnagar, Gujarat with a single mission — bring authentic Ayurveda back into Indian homes.</p>
          </div>
        </div>
        <div class="about-timeline__item">
          <div class="about-timeline__year">2012</div>
          <div class="about-timeline__body">
            <h4>GMP Certification</h4>
            <p>Our facility receives full GMP certification, allowing us to scale manufacturing without compromising on purity.</p>
          </div>
        </div>
        <div class="about-timeline__item">
          <div class="about-timeline__year">2015</div>
          <div class="about-timeline__body">
            <h4>AYUSH Licensing</h4>
            <p>Officially licensed by the Ministry of AYUSH, validating our formulations against classical Ayurvedic standards.</p>
          </div>
        </div>
        <div class="about-timeline__item">
          <div class="about-timeline__year">2018</div>
          <div class="about-timeline__body">
            <h4>HerboVilla Brand Launches</h4>
            <p>The HerboVilla consumer brand is launched, taking our flagship formulations directly to households across India.</p>
          </div>
        </div>
        <div class="about-timeline__item">
          <div class="about-timeline__year">2021</div>
          <div class="about-timeline__body">
            <h4>ISO 9001:2015</h4>
            <p>Achieved international ISO 9001:2015 quality management certification across all production lines.</p>
          </div>
        </div>
        <div class="about-timeline__item">
          <div class="about-timeline__year">2024</div>
          <div class="about-timeline__body">
            <h4>50,000+ Families Served</h4>
            <p>Crossed 50,000 active customers nationwide with a product range spanning 44+ trusted Ayurvedic formulations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Testimonials {%- endcomment -%}
  <section class="about-testimonials section">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-header__label">{{ section.settings.tst_label | default: 'In Their Words' }}</span>
        <h2 class="section-header__title">{{ section.settings.tst_title | default: 'What Our Customers Say' }}</h2>
      </div>
      <div class="about-testimonials__grid">
        <figure class="about-testimonial">
          <blockquote>"I have been using PRM Castro Softgel for almost a year. My digestion has never been this comfortable. It feels like a remedy made by family, not a factory."</blockquote>
          <figcaption>— Anjali M., Ahmedabad</figcaption>
        </figure>
        <figure class="about-testimonial">
          <blockquote>"What I love most is the freshness. Every bottle smells like real herbs, not chemicals. PRM HerboVilla has earned a permanent place in my mother's medicine cabinet."</blockquote>
          <figcaption>— Rohit S., Mumbai</figcaption>
        </figure>
        <figure class="about-testimonial">
          <blockquote>"Vedacold actually works. My family has stopped buying every cough syrup on the shelf — this one is gentle, effective, and trustworthy."</blockquote>
          <figcaption>— Priya K., Pune</figcaption>
        </figure>
      </div>
    </div>
  </section>

  {%- comment -%} Awards & Certifications {%- endcomment -%}
  <section class="about-awards section section--alt">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-header__label">{{ section.settings.awards_label | default: 'Recognitions' }}</span>
        <h2 class="section-header__title">{{ section.settings.awards_title | default: 'Certifications & Approvals' }}</h2>
      </div>
      <div class="about-awards__grid">
        <div class="about-awards__badge">
          <div class="about-awards__icon">GMP</div>
          <div class="about-awards__name">Good Manufacturing Practices</div>
          <div class="about-awards__desc">WHO-aligned GMP certification for our entire production facility.</div>
        </div>
        <div class="about-awards__badge">
          <div class="about-awards__icon">ISO</div>
          <div class="about-awards__name">ISO 9001:2015</div>
          <div class="about-awards__desc">International quality management standard, audited annually.</div>
        </div>
        <div class="about-awards__badge">
          <div class="about-awards__icon">AYUSH</div>
          <div class="about-awards__name">Ministry of AYUSH</div>
          <div class="about-awards__desc">Licensed Ayurvedic manufacturer under the Government of India.</div>
        </div>
        <div class="about-awards__badge">
          <div class="about-awards__icon">FSSAI</div>
          <div class="about-awards__name">FSSAI Compliant</div>
          <div class="about-awards__desc">Full food-safety compliance for all consumable formulations.</div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Contact CTA {%- endcomment -%}
  <section class="about-cta section">
    <div class="container">
      <div class="about-cta__content">
        <h2 class="about-cta__title">{{ section.settings.cta_title | default: 'Have Questions? We\'re Here to Help' }}</h2>
        <p class="about-cta__text">{{ section.settings.cta_text | default: 'Our team is ready to assist you on your wellness journey. Reach out to us for product recommendations or any queries.' }}</p>
        <div class="about-cta__buttons">
          <a href="{{ section.settings.cta_button_url | default: '/pages/contact' }}" class="btn btn--primary">
            {{ section.settings.cta_button_text | default: 'Contact Us' }}
          </a>
          <a href="{{ section.settings.cta_button_2_url | default: '/collections/all' }}" class="btn btn--outline">
            {{ section.settings.cta_button_2_text | default: 'Shop Products' }}
          </a>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .about-page {
    --about-spacing: 5rem;
  }

  /* Hero */
  .about-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e4d3a 100%);
    color: var(--color-white);
    padding: 5rem 0;
    text-align: center;
  }

  .about-hero__label {
    display: inline-block;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .about-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    margin-bottom: 1.5rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .about-hero__text {
    font-size: 1.125rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Mission Section */
  .about-mission__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-mission__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .about-mission__image img,
  .about-mission__placeholder {
    width: 100%;
    border-radius: var(--radius-lg);
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .about-mission__placeholder {
    background: var(--color-background-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-mission__placeholder svg {
    width: 64px;
    height: 64px;
    color: var(--color-primary);
    opacity: 0.5;
  }

  .about-mission__label {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .about-mission__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .about-mission__text {
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .about-mission__text p + p {
    margin-top: 1rem;
  }

  /* Values Section */
  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .value-card {
    background: var(--color-white);
    padding: 2rem;
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .value-card__icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e4d3a 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .value-card__icon svg {
    width: 28px;
    height: 28px;
    color: var(--color-white);
  }

  .value-card__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-text);
