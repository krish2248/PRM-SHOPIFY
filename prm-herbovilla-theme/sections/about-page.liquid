    margin-bottom: 0.6rem;
  }

  .value-card__text {
    color: #555;
    font-size: 0.92rem;
    line-height: 1.65;
  }

  /* Timeline */
  .about-timeline {
    max-width: 900px;
    margin: 44px auto 0;
    position: relative;
  }

  .about-timeline::before {
    content: '';
    position: absolute;
    left: 110px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, transparent, #40916C 15%, #40916C 85%, transparent);
  }

  .about-timeline__item {
    display: grid;
    grid-template-columns: 90px 30px 1fr;
    gap: 20px;
    align-items: flex-start;
    padding: 20px 0;
    position: relative;
  }

  .about-timeline__item::before {
    content: '';
    position: absolute;
    left: 104px;
    top: 30px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #40916C;
    border: 3px solid #FDF8F0;
    z-index: 1;
  }

  .about-timeline__item--highlight::before {
    background: #8B5E3C;
    width: 18px;
    height: 18px;
    left: 102px;
    top: 28px;
  }

  .about-timeline__year {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #2D6A4F;
    text-align: right;
  }

  .about-timeline__item--highlight .about-timeline__year {
    color: #8B5E3C;
  }

  .about-timeline__body {
    grid-column: 3;
    background: #fff;
    padding: 18px 22px;
    border-radius: 12px;
    border: 1px solid #EFE7D9;
  }

  .about-timeline__item--highlight .about-timeline__body {
    background: linear-gradient(135deg, #fff 0%, #FFF8E1 100%);
    border-color: #E8DEC8;
  }

  .about-timeline__body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #1B4332;
    margin: 0 0 6px;
  }

  .about-timeline__body p {
    color: #555;
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
  }

  /* Leadership */
  .about-leadership__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 28px;
    margin-top: 36px;
    max-width: 1180px;
    margin-left: auto;
    margin-right: auto;
  }

  .about-leader {
    background: #fff;
    padding: 30px 28px;
    border-radius: 18px;
    border: 1px solid #EFE7D9;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
    text-align: left;
  }

  .about-leader--rich { display: flex; flex-direction: column; gap: 16px; }

  .about-leader__head {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .about-leader__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .about-leader__avatar--alt {
    background: linear-gradient(135deg, #8B5E3C 0%, #5a3f28 100%);
  }

  .about-leader__name {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    color: #1B4332;
    margin: 0 0 2px;
  }

  .about-leader__role {
    color: #8B5E3C;
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 2px;
  }
  .about-leader__since {
    color: #888;
    font-size: 0.78rem;
    margin: 0;
    font-style: italic;
  }

  .about-leader__bio {
    color: #555;
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
  }

  .about-leader__beliefs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .about-leader__beliefs li {
    position: relative;
    padding: 10px 14px 10px 30px;
    background: #f8fdf8;
    border-left: 3px solid #2D6A4F;
    border-radius: 6px;
    font-size: 0.86rem;
    color: #444;
    line-height: 1.55;
  }
  .about-leader__beliefs li::before {
    content: "✓";
    position: absolute;
    left: 10px;
    top: 10px;
    color: #2D6A4F;
    font-weight: 700;
  }
  .about-leader__beliefs strong { color: #1B4332; }

  .about-leader__quote {
    margin: 0;
    padding: 16px 18px;
    background: linear-gradient(135deg, rgba(45, 106, 79, 0.06) 0%, rgba(139, 94, 60, 0.04) 100%);
    border-radius: 10px;
    border-left: 4px solid #8B5E3C;
  }
  .about-leader__quote p {
    margin: 0 0 8px;
    color: #1B4332;
    font-family: 'Playfair Display', serif;
    font-size: 0.98rem;
    line-height: 1.55;
    font-style: italic;
  }
  .about-leader__quote cite {
    color: #8B5E3C;
    font-size: 0.78rem;
    font-weight: 600;
    font-style: normal;
    letter-spacing: 0.5px;
  }

  .about-leader__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    padding-top: 12px;
    border-top: 1px dashed #EFE7D9;
  }
  .about-leader__stats div {
    text-align: center;
    font-size: 0.72rem;
    color: #777;
    line-height: 1.3;
  }
  .about-leader__stats span {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #2D6A4F;
    margin-bottom: 2px;
  }

  /* Values grid */
  .about-leadership__values {
    margin-top: 56px;
    padding-top: 48px;
    border-top: 1px solid #EFE7D9;
  }
  .about-leadership__values-head {
    text-align: center;
    margin-bottom: 32px;
  }
  .about-leadership__values-head h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    color: #1B4332;
    margin: 8px 0 0;
  }
  .about-leadership__values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    max-width: 1180px;
    margin: 0 auto;
  }
  .about-value {
    background: #fff;
    padding: 22px 20px;
    border-radius: 14px;
    border: 1px solid #EFE7D9;
    text-align: left;
  }
  .about-value__icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(45, 106, 79, 0.1);
    color: #2D6A4F;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .about-value__icon svg { width: 20px; height: 20px; }
  .about-value h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.02rem;
    color: #1B4332;
    margin: 0 0 6px;
  }
  .about-value p {
    color: #555;
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0;
  }

  /* Mission band */
  .about-leadership__mission {
    margin-top: 48px;
    padding: 36px 28px;
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    border-radius: 20px;
    color: #fff;
  }
  .about-leadership__mission-head {
    text-align: center;
    margin-bottom: 24px;
  }
  .about-leadership__mission-head .section-header__label {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  .about-leadership__mission-head h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin: 8px 0 0;
    color: #fff;
  }
  .about-leadership__mission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .about-mission-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    padding: 20px 22px;
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }
  .about-mission-card h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    margin: 0 0 8px;
    color: #fff;
  }
  .about-mission-card p {
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 900px) {
    .about-leadership__values-grid { grid-template-columns: repeat(2, 1fr); }
    .about-leadership__mission-grid { grid-template-columns: 1fr; }
    .about-leadership__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .about-leadership__values-grid { grid-template-columns: 1fr; }
    .about-leader { padding: 24px 20px; }
    .about-leader__stats { grid-template-columns: repeat(3, 1fr); gap: 6px; }
    .about-leader__stats span { font-size: 1rem; }
    .about-leadership__mission { padding: 28px 20px; }
  }

  /* Manufacturing */
  .about-manufacturing__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .about-manufacturing__label {
    display: inline-block;
    font-size: 0.85rem;
    color: #2D6A4F;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .about-manufacturing__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    color: #1a1a1a;
    margin-bottom: 1.3rem;
    line-height: 1.25;
  }

  .about-manufacturing__text {
    color: #555;
    line-height: 1.85;
    margin-bottom: 1.6rem;
  }

  .about-manufacturing__text p + p {
    margin-top: 0.9rem;
  }

  .about-manufacturing__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 4px 20px;
  }

  .about-manufacturing__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    color: #333;
    font-size: 0.92rem;
  }

  .about-manufacturing__feature svg {
    width: 18px;
    height: 18px;
    color: #2D6A4F;
    flex-shrink: 0;
  }

  .about-manufacturing__image img,
  .about-manufacturing__placeholder {
    width: 100%;
    border-radius: 16px;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .about-manufacturing__placeholder {
    background: linear-gradient(135deg, #E8F5E9 0%, #B7E4C7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
  }

  .about-manufacturing__placeholder svg {
    width: 120px;
    height: 120px;
    color: #1B4332;
    opacity: 0.55;
  }

  .about-manufacturing__placeholder span {
    font-size: 0.9rem;
    color: #1B4332;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Certifications */
  .about-certs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 22px;
    margin-top: 40px;
  }

  .about-cert {
    background: #fff;
    border: 1px solid #EFE7D9;
    border-radius: 14px;
    padding: 26px 22px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .about-cert:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(27, 67, 50, 0.08);
  }

  .about-cert__icon {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
    letter-spacing: 0.04em;
  }

  .about-cert__icon--small {
    font-size: 0.85rem;
  }

  .about-cert h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #1B4332;
    margin: 0 0 8px;
  }

  .about-cert p {
    color: #555;
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA */
  .about-cta {
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
  }

  .about-cta__content {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .about-cta__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.6vw, 2.3rem);
    margin-bottom: 0.9rem;
    color: #fff;
  }

  .about-cta__text {
    font-size: 1.02rem;
    opacity: 0.92;
    margin-bottom: 1.6rem;
    line-height: 1.7;
  }

  .about-cta__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .about-cta .btn--primary {
    background: #fff;
    color: #2D6A4F;
    border-color: #fff;
  }

  .about-cta .btn--primary:hover {
    background: #FDF8F0;
  }

  .about-cta .btn--outline {
    border-color: #fff;
    color: #fff;
    background: transparent;
  }

  .about-cta .btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Tablet & mobile */
  @media (max-width: 900px) {
    .about-parent__grid,
    .about-mission__grid,
    .about-manufacturing__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .about-mission__image,
    .about-manufacturing__image {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .about-timeline::before {
      left: 30px;
    }

    .about-timeline__item {
      grid-template-columns: 1fr;
      padding-left: 60px;
    }

    .about-timeline__item::before {
      left: 24px;
      top: 24px;
    }

    .about-timeline__item--highlight::before {
      left: 22px;
    }

    .about-timeline__year {
      text-align: left;
      margin-bottom: 6px;
    }

    .about-timeline__body {
      grid-column: 1;
    }

    .about-hero__badge {
      font-size: 0.7rem;
      padding: 5px 10px;
    }

    .about-parent__card {
      padding: 22px;
    }

    .about-cta__buttons .btn {
      flex: 1 1 100%;
      justify-content: center;
    }
  }

  /* =======================================================
     Doshas — The Philosophy of Ayurveda
     ======================================================= */
  .about-doshas {
    padding: clamp(56px, 7vw, 96px) 20px;
  }

  .about-doshas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
    margin-top: 2.5rem;
  }

  .dosha-card {
    position: relative;
    background: #fff;
    border: 1px solid #E8DEC8;
    border-radius: 20px;
    padding: 32px 26px 28px;
    text-align: center;
    box-shadow: 0 16px 40px rgba(27, 67, 50, 0.06);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .dosha-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
  }

  .dosha-card--vata::before { background: linear-gradient(90deg, #8AB6D6, #5E8BAF); }
  .dosha-card--pitta::before { background: linear-gradient(90deg, #E39A5A, #C66A3C); }
  .dosha-card--kapha::before { background: linear-gradient(90deg, #7EAF8C, #4D8062); }

  .dosha-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 50px rgba(27, 67, 50, 0.12);
  }

  .dosha-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #FDF8F0;
  }

  .dosha-card__icon svg { width: 36px; height: 36px; }

  .dosha-card--vata .dosha-card__icon { color: #5E8BAF; background: #EDF4FA; }
  .dosha-card--pitta .dosha-card__icon { color: #C66A3C; background: #FBEFE5; }
  .dosha-card--kapha .dosha-card__icon { color: #4D8062; background: #EBF3EE; }

  .dosha-card__script {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #1B4332;
    opacity: 0.85;
    margin-bottom: 4px;
  }

  .dosha-card--vata .dosha-card__script { color: #3F6B8F; }
  .dosha-card--pitta .dosha-card__script { color: #A25023; }
  .dosha-card--kapha .dosha-card__script { color: #2D6A4F; }

  .dosha-card__name {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: #1B4332;
    margin: 0 0 4px;
    letter-spacing: 0.02em;
  }

  .dosha-card__element {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #8B5E3C;
    margin: 0 0 14px;
    font-weight: 600;
  }

  .dosha-card__text {
    color: #4a4a4a;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 18px;
  }

  .dosha-card__herbs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
  }

  .dosha-card__herbs span {
    background: #FDF8F0;
    color: #1B4332;
    font-size: 0.78rem;
    padding: 5px 11px;
    border-radius: 30px;
    border: 1px solid #EFE7D9;
    font-weight: 500;
  }

  .about-doshas__footnote {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin: 2.5rem auto 0;
    max-width: 640px;
    background: #fff;
    border: 1px dashed #C9A55C;
    border-radius: 14px;
    padding: 14px 20px;
    font-size: 0.92rem;
    color: #555;
    text-align: left;
  }

  .about-doshas__footnote svg {
    width: 20px;
    height: 20px;
    color: #8B5E3C;
    flex-shrink: 0;
  }

  /* =======================================================
     Signature Herbs
     ======================================================= */
  .about-herbs { padding: clamp(56px, 7vw, 96px) 20px; background: #fff; }

  .about-herbs__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 2.5rem;
  }

  .herb-card {
    position: relative;
    background: linear-gradient(165deg, #FDF8F0 0%, #F5EDE0 100%);
    border: 1px solid #E8DEC8;
    border-radius: 20px;
    padding: 28px 24px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .herb-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 48px rgba(27, 67, 50, 0.1);
  }

  .herb-card__visual {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #E8DEC8;
    color: #2D6A4F;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .herb-card__visual svg { width: 52px; height: 52px; }

  .herb-card__script {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    color: #8B5E3C;
    opacity: 0.85;
    margin-bottom: 2px;
  }

  .herb-card__name {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: #1B4332;
    margin: 2px 0 2px;
  }

  .herb-card__latin {
    font-size: 0.8rem;
    font-style: italic;
    color: #8B5E3C;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }

  .herb-card__desc {
    color: #4a4a4a;
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .herb-card__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 5px;
  }

  .herb-card__tags span {
    background: rgba(45, 106, 79, 0.09);
    color: #1B4332;
    font-size: 0.72rem;
    padding: 4px 10px;
    border-radius: 30px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .about-herbs__note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 2.6rem auto 0;
    max-width: 720px;
    background: #FDF8F0;
    border: 1px solid #EFE7D9;
    border-radius: 14px;
    padding: 16px 22px;
    font-size: 0.95rem;
    color: #1B4332;
  }

  .about-herbs__note svg { width: 22px; height: 22px; color: #C9A55C; flex-shrink: 0; }

  /* =======================================================
     From Farm to Family — Process
     ======================================================= */
  .about-process { padding: clamp(56px, 7vw, 96px) 20px; background: #FDF8F0; }

  .about-process__grid {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    counter-reset: step;
  }

  .process-step {
    position: relative;
    background: #fff;
    border-radius: 18px;
    padding: 28px 24px 24px;
    border: 1px solid #E8DEC8;
    text-align: left;
