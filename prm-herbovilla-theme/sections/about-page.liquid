  .sustain-card__icon--earth { background: rgba(139, 94, 60, 0.14); color: #8B5E3C; }
  .sustain-card__icon--community { background: rgba(201, 165, 92, 0.2); color: #8B6B28; }
  .sustain-card__icon--camp { background: rgba(74, 124, 89, 0.15); color: #3B6848; }
  .sustain-card__icon--solar { background: rgba(231, 165, 62, 0.18); color: #B57A12; }

