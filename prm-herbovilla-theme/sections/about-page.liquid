{%- comment -%}
  About Us Page Template
  HerboVilla — the Ayurvedic & herbal wellness division of PRM Pharmaceuticals
  Only renders on About pages so it can safely co-exist in the default page template.
{%- endcomment -%}

{%- if page.handle == 'about-us' or page.handle == 'about' -%}
<div class="about-page">
  {%- comment -%} Hero {%- endcomment -%}
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__layout">
        <div class="about-hero__content">
          <span class="about-hero__label">{{ section.settings.hero_label | default: 'Our Story' }}</span>
          <h1 class="about-hero__title">{{ section.settings.hero_title | default: 'Rooted in Tradition, Driven by Wellness' }}</h1>
          <p class="about-hero__tagline">— Extending Healthy Horizons —</p>
          <p class="about-hero__text">{{ section.settings.hero_text | default: "HerboVilla is the Ayurvedic and herbal wellness division of PRM Pharmaceuticals — a 25-year-old Indian pharmaceutical house serving more than three lakh healthcare professionals across 28 states." }}</p>
          <div class="about-hero__badges">
            <span class="about-hero__badge">Founded 1999 · Bhavnagar</span>
            <span class="about-hero__badge">HerboVilla Division · 2013</span>
          </div>
        </div>
        <div class="about-hero__media">
          <img src="{{ 'herbovilla-transparent.png' | asset_url }}" alt="PRM HerboVilla — the ayurveda ethics" class="about-hero__logo" loading="eager" width="520" height="420">
        </div>
      </div>
    </div>
  </section>

