     FAQ
     ======================================================= */
  .about-faq { padding: clamp(56px, 7vw, 96px) 20px; }

  .about-faq__container { max-width: 860px; }

  .about-faq__list {
    margin-top: 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: #fff;
    border: 1px solid #E8DEC8;
    border-radius: 14px;
    overflow: hidden;
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .faq-item[open] {
    border-color: #2D6A4F;
    box-shadow: 0 14px 34px rgba(27, 67, 50, 0.08);
  }

  .faq-item__q {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    cursor: pointer;
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: #1B4332;
    font-weight: 600;
    transition: background 0.2s ease;
  }

  .faq-item__q::-webkit-details-marker { display: none; }

  .faq-item__q:hover { background: #FDF8F0; }

  .faq-item__q svg {
    width: 20px;
    height: 20px;
    color: #8B5E3C;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq-item[open] .faq-item__q svg { transform: rotate(180deg); color: #2D6A4F; }

  .faq-item__a {
    padding: 0 22px 20px;
    color: #4a4a4a;
  }

  .faq-item__a p {
    margin: 0;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .faq-item__a a {
    color: #2D6A4F;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* =======================================================
     Responsive tweaks for new sections
     ======================================================= */
  @media (max-width: 992px) {
    .about-doshas__grid,
    .about-herbs__grid,
    .about-process__grid,
    .about-why__grid,
    .about-sustain__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .about-doshas__grid,
    .about-herbs__grid,
    .about-process__grid,
    .about-why__grid,
    .about-sustain__grid {
      grid-template-columns: 1fr;
    }

    .about-compare__row {
      grid-template-columns: 1fr;
      padding: 14px 18px;
      gap: 4px;
    }

    .about-compare__row--head {
      display: none;
    }

    .about-compare__row > div:first-child {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #8B5E3C;
    }

    .faq-item__q {
      font-size: 0.98rem;
      padding: 16px 18px;
    }

    .faq-item__a {
      padding: 0 18px 18px;
    }
  }
</style>

