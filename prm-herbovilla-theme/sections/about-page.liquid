                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <circle cx="40" cy="30" r="14"/>
                  <path d="M12 70c4-14 14-22 28-22s24 8 28 22"/>
