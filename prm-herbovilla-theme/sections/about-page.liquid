  /* =======================================================
     Image Showcase
     ======================================================= */
  .about-showcase {
    padding: clamp(48px, 6vw, 80px) 20px clamp(40px, 5vw, 64px);
    background: #fff;
  }
  .about-showcase__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 36px;
  }
  .about-showcase__label {
    display: inline-block;
