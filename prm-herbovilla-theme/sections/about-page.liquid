  }
  .about-value__icon svg { width: 20px; height: 20px; }
  .about-value h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.02rem;
    color: #1B4332;
    margin: 0 0 6px;
  }
  .about-value p {
    color: #555;
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0;
  }

  /* Mission band */
  .about-leadership__mission {
    margin-top: 48px;
    padding: 36px 28px;
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    border-radius: 20px;
    color: #fff;
  }
  .about-leadership__mission-head {
    text-align: center;
    margin-bottom: 24px;
  }
  .about-leadership__mission-head .section-header__label {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  .about-leadership__mission-head h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin: 8px 0 0;
    color: #fff;
  }
  .about-leadership__mission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .about-mission-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
