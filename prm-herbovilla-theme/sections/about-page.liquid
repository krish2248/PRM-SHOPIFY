    color: #1B4332;
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .team-card__text {
    font-size: 0.86rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .team-card__skills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .team-card__skills li {
    background: #F1F8F3;
    border: 1px solid #DCEBE0;
    color: #2D6A4F;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .about-team__culture {
    margin-top: 56px;
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    border-radius: 22px;
    padding: clamp(28px, 4vw, 44px);
    color: #fff;
  }
  .about-team__culture-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 36px;
    align-items: center;
  }
  .about-team__culture-copy .section-header__label {
    color: #B7E4C7;
  }
  .about-team__culture-copy h3 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    color: #fff;
    margin: 8px 0 14px;
    line-height: 1.25;
  }
  .about-team__culture-copy p {
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.75;
    font-size: 0.95rem;
    margin: 0 0 14px;
  }
  .about-team__culture-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }
  .about-team__culture-list li {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    padding: 14px 18px;
    display: flex;
    align-items: baseline;
    gap: 14px;
    backdrop-filter: blur(4px);
  }
  .about-team__culture-list li strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: #fff;
    flex-shrink: 0;
    min-width: 90px;
  }
  .about-team__culture-list li span {
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  @media (max-width: 1100px) {
    .about-team__stats { grid-template-columns: repeat(3, 1fr); }
    .about-team__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 900px) {
    .about-team__culture-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .about-team__stats { grid-template-columns: repeat(2, 1fr); }
    .about-team__grid { grid-template-columns: 1fr; }
    .team-card__avatar { width: 50px; height: 50px; }
  }

  /* =======================================================
     Responsive tweaks for new sections
     ======================================================= */
  @media (max-width: 992px) {
    .about-doshas__grid,
    .about-herbs__grid,
    .about-process__grid,
    .about-why__grid,
    .about-sustain__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .about-doshas__grid,
    .about-herbs__grid,
    .about-process__grid,
    .about-why__grid,
    .about-sustain__grid {
      grid-template-columns: 1fr;
    }

    .about-compare__row {
      grid-template-columns: 1fr;
      padding: 14px 18px;
      gap: 4px;
    }

    .about-compare__row--head {
      display: none;
    }

    .about-compare__row > div:first-child {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #8B5E3C;
    }

    .faq-item__q {
      font-size: 0.98rem;
      padding: 16px 18px;
    }

    .faq-item__a {
      padding: 0 18px 18px;
    }
  }
