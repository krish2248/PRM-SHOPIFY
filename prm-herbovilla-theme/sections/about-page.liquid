  /* Manufacturing */
  .about-manufacturing__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .about-manufacturing__label {
    display: inline-block;
    font-size: 0.85rem;
    color: #2D6A4F;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .about-manufacturing__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    color: #1a1a1a;
    margin-bottom: 1.3rem;
    line-height: 1.25;
  }

  .about-manufacturing__text {
    color: #555;
    line-height: 1.85;
    margin-bottom: 1.6rem;
  }

  .about-manufacturing__text p + p {
    margin-top: 0.9rem;
  }

  .about-manufacturing__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 4px 20px;
  }

  .about-manufacturing__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    color: #333;
    font-size: 0.92rem;
  }

  .about-manufacturing__feature svg {
    width: 18px;
    height: 18px;
    color: #2D6A4F;
    flex-shrink: 0;
  }

  .about-manufacturing__image img,
  .about-manufacturing__placeholder {
    width: 100%;
    border-radius: 16px;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .about-manufacturing__placeholder {
    background: linear-gradient(135deg, #E8F5E9 0%, #B7E4C7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 12px;
  }

  .about-manufacturing__placeholder svg {
    width: 120px;
    height: 120px;
    color: #1B4332;
    opacity: 0.55;
  }

  .about-manufacturing__placeholder span {
    font-size: 0.9rem;
    color: #1B4332;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* Certifications */
  .about-certs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 22px;
    margin-top: 40px;
  }

  .about-cert {
    background: #fff;
    border: 1px solid #EFE7D9;
    border-radius: 14px;
    padding: 26px 22px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .about-cert:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(27, 67, 50, 0.08);
  }

  .about-cert__icon {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
    letter-spacing: 0.04em;
  }

  .about-cert__icon--small {
    font-size: 0.85rem;
  }

  .about-cert h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #1B4332;
    margin: 0 0 8px;
  }

  .about-cert p {
    color: #555;
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Connect — social / brand sites / marketplaces */
  .about-connect {
    background: #fdf8f0;
    padding: clamp(48px, 7vw, 80px) 20px;
  }
  .about-connect__head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 48px;
  }
  .about-connect__label {
    display: inline-block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #2D6A4F;
    background: rgba(45, 106, 79, 0.1);
    padding: 6px 14px;
    border-radius: 50px;
    margin-bottom: 14px;
  }
  .about-connect__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3.5vw, 2.2rem);
    color: #1a1a1a;
    line-height: 1.2;
    margin-bottom: 14px;
  }
  .about-connect__text {
    color: #555;
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
  }
  .about-connect__block {
    max-width: 1080px;
    margin: 0 auto 40px;
  }
  .about-connect__block:last-child { margin-bottom: 0; }
  .about-connect__sub {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #1a1a1a;
    margin-bottom: 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(45, 106, 79, 0.18);
  }
  .about-connect__socials {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .about-connect__social {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: #fff;
    border: 1px solid #e8ebe0;
    border-radius: 12px;
    color: #1a1a1a;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .about-connect__social svg {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: #2D6A4F;
  }
  .about-connect__social:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(45, 106, 79, 0.12);
    border-color: rgba(45, 106, 79, 0.35);
  }
  .about-connect__social--linkedin:hover  { border-color: #0a66c2; }
  .about-connect__social--linkedin:hover svg { color: #0a66c2; }
  .about-connect__social--instagram:hover { border-color: #E1306C; }
  .about-connect__social--instagram:hover svg { color: #E1306C; }
  .about-connect__social--facebook:hover  { border-color: #1877F2; }
  .about-connect__social--facebook:hover svg { color: #1877F2; }
  .about-connect__social--youtube:hover   { border-color: #FF0000; }
  .about-connect__social--youtube:hover svg { color: #FF0000; }

  .about-connect__brands {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  .about-connect__brand {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: #fff;
    border: 1px solid #e8ebe0;
    border-radius: 14px;
    color: #1a1a1a;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .about-connect__brand:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(45, 106, 79, 0.14);
    border-color: rgba(45, 106, 79, 0.4);
  }
  .about-connect__brand-mark {
    width: 54px;
    height: 54px;
    border-radius: 12px;
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .about-connect__brand-mark--leaf svg {
    width: 26px;
    height: 26px;
    color: #fff;
  }
  .about-connect__brand-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .about-connect__brand-body strong {
    font-size: 1rem;
    color: #1a1a1a;
  }
  .about-connect__brand-body span {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.5;
  }
  .about-connect__brand-arrow {
    width: 20px;
    height: 20px;
    color: #2D6A4F;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .about-connect__brand:hover .about-connect__brand-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .about-connect__marketplaces {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .about-connect__marketplace {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px 18px;
    background: #fff;
    border: 1px solid #e8ebe0;
    border-radius: 12px;
    text-decoration: none;
    min-height: 84px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .about-connect__marketplace:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.1);
    border-color: rgba(45, 106, 79, 0.35);
  }
  .about-connect__mp-logo {
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }
  .about-connect__mp-logo--tata {
    color: #e23744;
    font-family: 'Inter', sans-serif;
  }
  .about-connect__mp-logo--amazon {
    color: #131921;
    font-family: 'Inter', sans-serif;
    text-transform: lowercase;
  }
  .about-connect__mp-logo--amazon span { color: #FF9900; }
  .about-connect__mp-logo--flipkart {
    color: #2874F0;
    font-family: 'Inter', sans-serif;
    font-style: italic;
  }
  .about-connect__mp-logo--meesho {
    color: #F43397;
    font-family: 'Inter', sans-serif;
  }

  @media (max-width: 900px) {
    .about-connect__socials,
    .about-connect__marketplaces {
      grid-template-columns: repeat(2, 1fr);
    }
    .about-connect__brands {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .about-connect__social {
      padding: 12px 14px;
      font-size: 0.88rem;
    }
    .about-connect__marketplace { min-height: 68px; padding: 16px 12px; }
    .about-connect__mp-logo { font-size: 1rem; }
    .about-connect__brand { padding: 16px; gap: 12px; }
    .about-connect__brand-mark { width: 46px; height: 46px; }
  }

  /* CTA */
  .about-cta {
    background: linear-gradient(135deg, #2D6A4F 0%, #1B4332 100%);
    color: #fff;
  }

  .about-cta__content {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .about-cta__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.6vw, 2.3rem);
    margin-bottom: 0.9rem;
    color: #fff;
  }

  .about-cta__text {
    font-size: 1.02rem;
    opacity: 0.92;
    margin-bottom: 1.6rem;
    line-height: 1.7;
  }

  .about-cta__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
  }

  .about-cta .btn--primary {
    background: #fff;
    color: #2D6A4F;
    border-color: #fff;
  }

  .about-cta .btn--primary:hover {
    background: #FDF8F0;
  }

  .about-cta .btn--outline {
    border-color: #fff;
    color: #fff;
    background: transparent;
  }

  .about-cta .btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Tablet & mobile */
  @media (max-width: 900px) {
    .about-parent__grid,
    .about-mission__grid,
    .about-manufacturing__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .about-mission__image,
    .about-manufacturing__image {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .about-timeline::before {
      left: 30px;
    }

    .about-timeline__item {
      grid-template-columns: 1fr;
      padding-left: 60px;
    }

    .about-timeline__item::before {
      left: 24px;
      top: 24px;
    }

    .about-timeline__item--highlight::before {
      left: 22px;
    }

    .about-timeline__year {
      text-align: left;
      margin-bottom: 6px;
    }

    .about-timeline__body {
      grid-column: 1;
    }

    .about-hero__badge {
      font-size: 0.7rem;
      padding: 5px 10px;
    }

    .about-parent__card {
      padding: 22px;
    }

    .about-cta__buttons .btn {
      flex: 1 1 100%;
      justify-content: center;
    }
  }

  /* =======================================================
     Doshas — The Philosophy of Ayurveda
     ======================================================= */
  .about-doshas {
    padding: clamp(56px, 7vw, 96px) 20px;
  }

  .about-doshas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
    margin-top: 2.5rem;
  }

  .dosha-card {
    position: relative;
    background: #fff;
    border: 1px solid #E8DEC8;
    border-radius: 20px;
    padding: 32px 26px 28px;
    text-align: center;
    box-shadow: 0 16px 40px rgba(27, 67, 50, 0.06);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .dosha-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
  }

  .dosha-card--vata::before { background: linear-gradient(90deg, #8AB6D6, #5E8BAF); }
  .dosha-card--pitta::before { background: linear-gradient(90deg, #E39A5A, #C66A3C); }
  .dosha-card--kapha::before { background: linear-gradient(90deg, #7EAF8C, #4D8062); }

  .dosha-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 50px rgba(27, 67, 50, 0.12);
  }

  .dosha-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #FDF8F0;
  }

  .dosha-card__icon svg { width: 36px; height: 36px; }

  .dosha-card--vata .dosha-card__icon { color: #5E8BAF; background: #EDF4FA; }
  .dosha-card--pitta .dosha-card__icon { color: #C66A3C; background: #FBEFE5; }
  .dosha-card--kapha .dosha-card__icon { color: #4D8062; background: #EBF3EE; }

  .dosha-card__script {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #1B4332;
    opacity: 0.85;
    margin-bottom: 4px;
  }

  .dosha-card--vata .dosha-card__script { color: #3F6B8F; }
  .dosha-card--pitta .dosha-card__script { color: #A25023; }
  .dosha-card--kapha .dosha-card__script { color: #2D6A4F; }

  .dosha-card__name {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: #1B4332;
    margin: 0 0 4px;
    letter-spacing: 0.02em;
  }

  .dosha-card__element {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #8B5E3C;
    margin: 0 0 14px;
    font-weight: 600;
  }

  .dosha-card__text {
    color: #4a4a4a;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 18px;
  }

  .dosha-card__herbs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
  }

  .dosha-card__herbs span {
    background: #FDF8F0;
    color: #1B4332;
    font-size: 0.78rem;
    padding: 5px 11px;
    border-radius: 30px;
    border: 1px solid #EFE7D9;
    font-weight: 500;
  }

  .about-doshas__footnote {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin: 2.5rem auto 0;
    max-width: 640px;
    background: #fff;
    border: 1px dashed #C9A55C;
    border-radius: 14px;
    padding: 14px 20px;
    font-size: 0.92rem;
    color: #555;
    text-align: left;
  }

  .about-doshas__footnote svg {
    width: 20px;
    height: 20px;
    color: #8B5E3C;
    flex-shrink: 0;
  }

  /* =======================================================
     Signature Herbs
     ======================================================= */
  .about-herbs { padding: clamp(56px, 7vw, 96px) 20px; background: #fff; }

  .about-herbs__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 2.5rem;
  }

  .herb-card {
    position: relative;
    background: linear-gradient(165deg, #FDF8F0 0%, #F5EDE0 100%);
    border: 1px solid #E8DEC8;
    border-radius: 20px;
    padding: 28px 24px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .herb-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 48px rgba(27, 67, 50, 0.1);
  }

  .herb-card__visual {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #E8DEC8;
    color: #2D6A4F;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .herb-card__visual svg { width: 52px; height: 52px; }

  .herb-card__script {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    color: #8B5E3C;
    opacity: 0.85;
    margin-bottom: 2px;
  }

  .herb-card__name {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: #1B4332;
    margin: 2px 0 2px;
  }

  .herb-card__latin {
    font-size: 0.8rem;
    font-style: italic;
    color: #8B5E3C;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
  }

  .herb-card__desc {
    color: #4a4a4a;
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0 0 14px;
  }

  .herb-card__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 5px;
  }

  .herb-card__tags span {
    background: rgba(45, 106, 79, 0.09);
    color: #1B4332;
    font-size: 0.72rem;
    padding: 4px 10px;
    border-radius: 30px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .about-herbs__note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 2.6rem auto 0;
    max-width: 720px;
    background: #FDF8F0;
    border: 1px solid #EFE7D9;
    border-radius: 14px;
    padding: 16px 22px;
    font-size: 0.95rem;
    color: #1B4332;
  }

  .about-herbs__note svg { width: 22px; height: 22px; color: #C9A55C; flex-shrink: 0; }

  /* =======================================================
     From Farm to Family — Process
     ======================================================= */
  .about-process { padding: clamp(56px, 7vw, 96px) 20px; background: #FDF8F0; }

  .about-process__grid {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
