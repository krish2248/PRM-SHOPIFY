    border-top: 1px dashed #C9A55C;
    padding-top: 10px;
    letter-spacing: 0.04em;
  }

  .sustain-card__stat strong {
    font-family: 'Playfair Display', serif;
    color: #1B4332;
    font-size: 1.15rem;
    margin-right: 6px;
  }

