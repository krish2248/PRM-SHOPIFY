              <path d="M20 6v4M20 30v4M6 20h4M30 20h4"/>
            </svg>
          </div>
          <h3 class="process-step__title">Identity Testing</h3>
          <p class="process-step__text">Every raw-material batch is organoleptically and chemically verified against pharmacopoeia standards before acceptance.</p>
        </li>

        <li class="process-step">
          <div class="process-step__num">03</div>
          <div class="process-step__icon">
            <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
