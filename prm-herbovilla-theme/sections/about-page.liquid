    margin-left: 2px;
    opacity: 0.85;
  }
  .showcase-stat__label {
    font-size: 0.92rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.95;
  }

  .showcase-tile figcaption {
