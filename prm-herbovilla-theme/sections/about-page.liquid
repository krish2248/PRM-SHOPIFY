  .about-compare__row {
    display: grid;
    grid-template-columns: 1.4fr 1.3fr 1.3fr;
    padding: 16px 24px;
    border-top: 1px solid #EFE7D9;
    align-items: center;
    font-size: 0.95rem;
    gap: 12px;
  }

  .about-compare__row > div:first-child {
    font-weight: 600;
    color: #1B4332;
