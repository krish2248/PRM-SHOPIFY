{%- comment -%}
  Blog Posts Section - Homepage blog with curated wellness articles
{%- endcomment -%}

{%- style -%}
.blog-posts-section .blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}
.blog-posts-section .blog-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 20px rgba(0,0,0,0.05);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}
.blog-posts-section .blog-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.1);
}
.blog-posts-section .blog-card__image {
  aspect-ratio: 16/10;
  overflow: hidden;
}
.blog-posts-section .blog-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.blog-posts-section .blog-card:hover .blog-card__image img {
  transform: scale(1.05);
}
.blog-posts-section .blog-card__content {
  padding: 25px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.blog-posts-section .blog-card__meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 15px;
  font-size: 0.82rem;
  color: var(--color-text-light);
}
.blog-posts-section .blog-card__category {
  background: rgba(45, 106, 79, 0.1);
  color: var(--color-primary);
  padding: 4px 12px;
  border-radius: 20px;
  font-weight: 500;
  font-size: 0.8rem;
  white-space: nowrap;
}
.blog-posts-section .blog-card__read-time {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.8rem;
  color: var(--color-text-light);
}
.blog-posts-section .blog-card__read-time svg {
  width: 13px;
  height: 13px;
}
.blog-posts-section .blog-card__title {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  margin-bottom: 12px;
  line-height: 1.4;
}
.blog-posts-section .blog-card__title a {
  color: var(--color-text);
  text-decoration: none;
  transition: color 0.3s ease;
}
.blog-posts-section .blog-card__title a:hover {
  color: var(--color-primary);
}
.blog-posts-section .blog-card__excerpt {
  color: var(--color-text-light);
  font-size: 0.92rem;
  line-height: 1.6;
  margin-bottom: 18px;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.blog-posts-section .blog-card__link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--color-primary);
  font-weight: 600;
  font-size: 0.9rem;
  text-decoration: none;
  margin-top: auto;
}
.blog-posts-section .blog-card__link svg {
  width: 16px;
  height: 16px;
  transition: transform 0.3s ease;
}
.blog-posts-section .blog-card__link:hover svg {
  transform: translateX(5px);
}
.blog-posts-section .blog-card__external {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.75rem;
  color: var(--color-text-light);
  margin-top: 8px;
  opacity: 0.7;
}
.blog-posts-section .blog-card__external svg {
  width: 11px;
  height: 11px;
}
@media (max-width: 992px) {
  .blog-posts-section .blog-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 576px) {
  .blog-posts-section .blog-grid {
    grid-template-columns: 1fr;
  }
}
{%- endstyle -%}

<section class="section {% if section.settings.alt_background %}section--alt{% endif %}">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.label != blank -%}
        <span class="section-header__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="section-header__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>
    
    <div class="blog-grid">
      {%- liquid
        if section.settings.blog != blank
          assign articles = section.settings.blog.articles
        endif
      -%}
      
      {%- for article in articles limit: section.settings.articles_count -%}
        <article class="blog-card">
          {%- if article.image -%}
            <div class="blog-card__image">
              <a href="{{ article.url }}">
                <img 
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="600"
                  height="375"
                >
              </a>
            </div>
          {%- endif -%}
          
          <div class="blog-card__content">
            <div class="blog-card__meta">
              <span class="blog-card__category">{{ article.tags.first | default: 'Ayurveda' }}</span>
              <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
            </div>
            
            <h3 class="blog-card__title">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h3>
            
            {%- if article.excerpt != blank -%}
              <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
            {%- endif -%}
            
            <a href="{{ article.url }}" class="blog-card__link">
              Read More
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </article>
      {%- else -%}
        {%- comment -%} Curated external articles about Ayurveda, herbal wellness & chemical-free living {%- endcomment -%}

