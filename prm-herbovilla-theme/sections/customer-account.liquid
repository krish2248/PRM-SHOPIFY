{%- style -%}
  .customer-account {
    padding: 0 0 80px;
    background: #FDF8F0;
    min-height: 80vh;
  }
  .acct-banner {
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    color: #fff;
    padding: 50px 0 90px;
    position: relative;
    overflow: hidden;
    margin-bottom: -60px;
  }
  .acct-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(2px 2px at 18% 28%, rgba(255,255,255,0.14) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 72% 68%, rgba(255,255,255,0.1) 50%, transparent 50%),
      radial-gradient(2px 2px at 42% 82%, rgba(255,255,255,0.12) 50%, transparent 50%);
    pointer-events: none;
  }
  .acct-banner__inner {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    z-index: 2;
  }
  .acct-banner__logo img { max-height: 48px; width: auto; filter: brightness(0) invert(1); }
  .acct-banner__logo-text {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
  }
  .acct-banner__logo-text span { color: #C9A55C; }
  .acct-banner__heading h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin: 0 0 6px;
    color: #fff;
    font-weight: 600;
  }
  .acct-banner__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #C9A55C;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .acct-banner__welcome {
    color: rgba(255,255,255,0.78);
    font-size: 0.92rem;
    margin: 0;
  }
  .acct-banner__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    font-size: 0.92rem;
    padding: 9px 18px;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 999px;
    transition: background 0.2s ease;
  }
  .acct-banner__cta:hover { background: rgba(255,255,255,0.12); }
  .acct-banner__cta svg { width: 16px; height: 16px; }
  .acct-grid-wrap {
    position: relative;
    z-index: 3;
  }
  .account-header { display: none; }
  .account-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 30px;
  }
  .account-sidebar {
    background: #fff;
    border-radius: 16px;
    padding: 25px;
    box-shadow: 0 4px 25px rgba(0,0,0,0.06);
    height: fit-content;
  }
  .account-profile {
    text-align: center;
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid #eee;
  }
  .account-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 15px;
    font-size: 2rem;
    font-weight: 600;
  }
  .account-name {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--color-text);
    margin-bottom: 5px;
  }
  .account-email {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }
  .account-nav {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .account-nav li {
    margin-bottom: 5px;
  }
  .account-nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 15px;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.3s ease;
    font-weight: 500;
  }
  .account-nav a:hover,
  .account-nav a.active {
    background: rgba(45, 106, 79, 0.1);
    color: var(--color-primary);
  }
  .account-nav svg {
    width: 20px;
    height: 20px;
  }
  .account-logout {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #eee;
  }
  .account-logout a {
    color: #dc2626;
  }
  .account-logout a:hover {
    background: #fee2e2;
    color: #dc2626;
  }
  .account-main {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }
  .account-card {
    background: #fff;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 4px 25px rgba(0,0,0,0.06);
  }
  .account-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
  }
  .account-card-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .account-card-title svg {
    width: 22px;
    height: 22px;
    color: var(--color-primary);
  }
  .account-card-action {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
  }
  .account-card-action:hover {
    text-decoration: underline;
  }
  
  /* Quick Stats */
  .account-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .stat-box {
    background: linear-gradient(135deg, #f8fdf8 0%, #e8f5e9 100%);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }
  .stat-box-icon {
    width: 45px;
    height: 45px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }
  .stat-box-icon svg {
    width: 22px;
    height: 22px;
  }
  .stat-box-number {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .stat-box-label {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-top: 5px;
  }
  
  /* Orders Table */
  .orders-table {
    width: 100%;
    border-collapse: collapse;
  }
  .orders-table th,
  .orders-table td {
    padding: 15px;
    text-align: left;
    border-bottom: 1px solid #f0f0f0;
  }
  .orders-table th {
    font-weight: 600;
    color: var(--color-text-light);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .orders-table tbody tr:hover {
    background: #f9f9f9;
  }
  .order-status {
    display: inline-block;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .order-status--fulfilled {
    background: #dcfce7;
    color: #16a34a;
  }
  .order-status--unfulfilled {
    background: #fef3c7;
    color: #d97706;
  }
  .order-status--cancelled {
    background: #fee2e2;
    color: #dc2626;
  }
  .view-order {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .view-order:hover {
    text-decoration: underline;
  }
  
  /* Address Card */
  .address-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .address-card {
    background: #f8f8f8;
    border-radius: 12px;
    padding: 20px;
    border: 1px solid #eee;
  }
  .address-card-badge {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 4px 10px;
    border-radius: 5px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .address-card p {
    line-height: 1.7;
    color: var(--color-text);
  }
  .address-card-actions {
    margin-top: 15px;
    display: flex;
    gap: 15px;
  }
  .address-card-actions a {
    font-size: 0.85rem;
    color: var(--color-primary);
    text-decoration: none;
  }
  .address-card-actions a:hover {
    text-decoration: underline;
  }
  
  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 50px 20px;
  }
  .empty-state-icon {
    width: 70px;
    height: 70px;
    background: #f0f0f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .empty-state-icon svg {
    width: 35px;
    height: 35px;
    color: var(--color-text-light);
  }
  .empty-state h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    margin-bottom: 10px;
  }
  .empty-state p {
    color: var(--color-text-light);
    margin-bottom: 20px;
  }
  .empty-state .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 25px;
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    border-radius: 25px;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  .empty-state .btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
  }
  
  /* Wellness Tips */
  .wellness-tip {
    background: linear-gradient(135deg, #f8fdf8 0%, #e8f5e9 100%);
    border-radius: 12px;
    padding: 20px;
    border-left: 4px solid var(--color-primary);
  }
  .wellness-tip-title {
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .wellness-tip-title svg {
    width: 18px;
    height: 18px;
  }
  .wellness-tip p {
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.6;
  }
  
  @media (max-width: 992px) {
    .account-grid {
      grid-template-columns: 1fr;
    }
    .account-sidebar {
      order: -1;
    }
    .account-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .account-stats {
      grid-template-columns: 1fr;
    }
    .address-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 768px) {
    .acct-banner__inner { grid-template-columns: 1fr; gap: 14px; }
    .acct-banner__cta { justify-self: flex-start; }
    .acct-banner__heading h1 { font-size: 1.65rem; }
  }
  @media (max-width: 576px) {
    .customer-account {
      padding: 0 0 60px;
    }
    .acct-banner { padding: 36px 0 80px; margin-bottom: -50px; }
    .acct-banner__heading h1 { font-size: 1.45rem; }
    .acct-banner__welcome { font-size: 0.85rem; }
    .account-title {
      font-size: 2rem;
    }
    .orders-table {
      display: block;
      overflow-x: auto;
    }
    .account-card {
      padding: 20px;
    }
  }
{%- endstyle -%}

<div class="acct-banner">
  <div class="container">
    <div class="acct-banner__inner">
      <div class="acct-banner__logo">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 240 }}" alt="{{ shop.name }} logo">
        {%- else -%}
          <span class="acct-banner__logo-text">Herbo<span>Villa</span></span>
        {%- endif -%}
      </div>
      <div class="acct-banner__heading">
        <p class="acct-banner__eyebrow">My Account</p>
        <h1>Namaste, {{ customer.first_name | default: customer.email }}</h1>
        <p class="acct-banner__welcome">Welcome back to your wellness journey — track orders, manage addresses and stay rooted in Ayurveda.</p>
      </div>
      <a href="/collections/all" class="acct-banner__cta">
        Shop Remedies
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</div>

<section class="customer-account">
  <div class="container acct-grid-wrap">
    <div class="account-grid">
      <aside class="account-sidebar">
        <div class="account-profile">
          <div class="account-avatar">
            {{ customer.first_name | slice: 0 | upcase | default: 'U' }}
          </div>
          <div class="account-name">{{ customer.first_name }} {{ customer.last_name }}</div>
          <div class="account-email">{{ customer.email }}</div>
        </div>
        
        <ul class="account-nav">
          <li>
            <a href="{{ routes.account_url }}" class="active">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
              Dashboard
            </a>
          </li>
          <li>
            <a href="{{ routes.account_url }}#orders">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
              My Orders
            </a>
          </li>
          <li>
            <a href="{{ routes.account_addresses_url }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Addresses
            </a>
          </li>
          <li>
            <a href="/pages/faq">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
              Help & Support
            </a>
          </li>
        </ul>
        
        <div class="account-logout">
          <a href="{{ routes.account_logout_url }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Sign Out
          </a>
        </div>
      </aside>
      
      <div class="account-main">
        <!-- Quick Stats -->
        <div class="account-card">
          <div class="account-stats">
            <div class="stat-box">
              <div class="stat-box-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
              </div>
              <div class="stat-box-number">{{ customer.orders.size }}</div>
              <div class="stat-box-label">Total Orders</div>
            </div>
            <div class="stat-box">
              <div class="stat-box-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div class="stat-box-number">{{ customer.addresses.size }}</div>
              <div class="stat-box-label">Saved Addresses</div>
            </div>
            <div class="stat-box">
              <div class="stat-box-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              </div>
              <div class="stat-box-number">{{ customer.tags.size | default: 0 }}</div>
              <div class="stat-box-label">Rewards Points</div>
            </div>
          </div>
        </div>
        
        <!-- Recent Orders -->
        <div class="account-card">
          <div class="account-card-header">
            <h2 class="account-card-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line></svg>
              Recent Orders
            </h2>
            {%- if customer.orders.size > 3 -%}
              <a href="{{ routes.account_url }}#all-orders" class="account-card-action">View All Orders</a>
            {%- endif -%}
          </div>
          
          {%- if customer.orders.size > 0 -%}
            <table class="orders-table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Total</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {%- for order in customer.orders limit: 5 -%}
                  <tr>
                    <td><strong>{{ order.name }}</strong></td>
                    <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
                    <td>
                      <span class="order-status order-status--{{ order.fulfillment_status | default: 'unfulfilled' }}">
                        {{ order.fulfillment_status_label | default: 'Processing' }}
                      </span>
                    </td>
                    <td><strong>{{ order.total_price | money }}</strong></td>
                    <td><a href="{{ order.customer_url }}" class="view-order">View Details</a></td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- else -%}
            <div class="empty-state">
              <div class="empty-state-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line></svg>
              </div>
              <h3>No orders yet</h3>
              <p>Start your wellness journey with our authentic Ayurvedic products</p>
              <a href="/collections/all" class="btn">
                Browse Products
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          {%- endif -%}
        </div>
        
        <!-- Default Address -->
        <div class="account-card">
          <div class="account-card-header">
            <h2 class="account-card-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Saved Addresses
            </h2>
            <a href="{{ routes.account_addresses_url }}" class="account-card-action">Manage Addresses</a>
          </div>
          
          {%- if customer.addresses.size > 0 -%}
            <div class="address-grid">
              {%- for address in customer.addresses limit: 2 -%}
                <div class="address-card">
                  {%- if address == customer.default_address -%}
                    <span class="address-card-badge">Default</span>
                  {%- endif -%}
                  <p>
                    <strong>{{ address.first_name }} {{ address.last_name }}</strong><br>
                    {{ address.address1 }}<br>
                    {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
                    {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                    {{ address.country }}
                  </p>
                  <div class="address-card-actions">
                    <a href="{{ routes.account_addresses_url }}">Edit</a>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="empty-state">
              <div class="empty-state-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <h3>No addresses saved</h3>
              <p>Add a shipping address for faster checkout</p>
              <a href="{{ routes.account_addresses_url }}" class="btn">Add Address</a>
            </div>
          {%- endif -%}
        </div>
        
        <!-- Wellness Tip -->
        <div class="account-card">
          <div class="wellness-tip">
            <div class="wellness-tip-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path></svg>
              Daily Wellness Tip
            </div>
            <p>Start your morning with warm water and a teaspoon of our herbal honey. This ancient Ayurvedic practice helps boost metabolism and supports digestive health throughout the day.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Account",
  "settings": []
}
{% endschema %}
