{%- style -%}
  .cart-template {
    padding: 40px 0 80px;
  }
  .cart-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .cart-title {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--color-text);
    margin-bottom: 10px;
  }
  .cart-count {
    color: var(--color-text-light);
    font-size: 1rem;
  }
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 50px;
    align-items: flex-start;
  }
  .cart-items {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 20px rgba(0,0,0,0.05);
  }
  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 25px;
    padding: 25px;
    border-bottom: 1px solid #eee;
    align-items: center;
  }
  .cart-item:last-child {
    border-bottom: none;
  }
  .cart-item__image {
    width: 120px;
    height: 120px;
    border-radius: 12px;
    overflow: hidden;
    background: #f8f8f8;
  }
  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-item__details {
    flex: 1;
  }
  .cart-item__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 5px;
    display: block;
  }
  .cart-item__title:hover {
    color: var(--color-primary);
  }
  .cart-item__variant {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 10px;
  }
  .cart-item__price {
    font-weight: 600;
    color: var(--color-primary);
  }
  .cart-item__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 15px;
  }
  .cart-item__quantity {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 8px;
    overflow: hidden;
  }
  .cart-qty-btn {
    width: 36px;
    height: 36px;
    background: #fff;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-text);
    transition: background 0.3s ease;
  }
  .cart-qty-btn:hover {
    background: #f5f5f5;
  }
  .cart-qty-input {
    width: 50px;
    height: 36px;
    border: none;
    border-left: 1px solid #ddd;
    border-right: 1px solid #ddd;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .cart-item__remove {
    background: none;
    border: none;
    color: var(--color-text-light);
    cursor: pointer;
    font-size: 0.85rem;
    text-decoration: underline;
    transition: color 0.3s ease;
  }
  .cart-item__remove:hover {
    color: #dc2626;
  }
  .cart-item__total {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .cart-summary {
    background: #fff;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.05);
    position: sticky;
    top: 120px;
  }
  .cart-summary__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
  }
  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    font-size: 0.95rem;
  }
  .cart-summary__row.total {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 20px;
    padding-top: 20px;
    border-top: 2px solid #eee;
  }
  .cart-summary__label {
    color: var(--color-text-light);
  }
  .cart-summary__value {
    font-weight: 600;
  }
  .cart-summary__value.free {
    color: #16a34a;
  }
  .cart-note {
    margin: 20px 0;
  }
  .cart-note label {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 8px;
  }
  .cart-note textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 0.9rem;
    resize: vertical;
    min-height: 80px;
  }
  .cart-checkout-btn {
    width: 100%;
    padding: 16px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 15px;
  }
  .cart-checkout-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(45, 106, 79, 0.3);
  }
  .cart-continue {
    display: block;
    text-align: center;
    color: var(--color-primary);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .cart-continue:hover {
    text-decoration: underline;
  }
  .cart-trust {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 25px;
    padding-top: 20px;
    border-top: 1px solid #eee;
  }
  .cart-trust svg {
    width: 24px;
    height: 24px;
    color: var(--color-text-light);
  }
  .cart-empty {
    text-align: center;
    padding: 80px 20px;
    max-width: 500px;
    margin: 0 auto;
  }
  .cart-empty svg {
    width: 100px;
    height: 100px;
    color: var(--color-text-light);
    opacity: 0.4;
    margin-bottom: 25px;
  }
  .cart-empty h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-bottom: 15px;
  }
  .cart-empty p {
    color: var(--color-text-light);
    margin-bottom: 30px;
  }
  .cart-empty a {
    display: inline-block;
    padding: 14px 35px;
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    border-radius: 30px;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  .cart-empty a:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
  }
  .free-shipping-bar {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    padding: 15px;
    margin-bottom: 20px;
    text-align: center;
  }
  .free-shipping-bar p {
    font-size: 0.9rem;
    color: #166534;
    margin-bottom: 8px;
  }
  .free-shipping-progress {
    height: 6px;
    background: #dcfce7;
    border-radius: 3px;
    overflow: hidden;
  }
  .free-shipping-progress__bar {
    height: 100%;
    background: #22c55e;
    border-radius: 3px;
    transition: width 0.3s ease;
  }
  @media (max-width: 992px) {
    .cart-layout {
      grid-template-columns: 1fr;
    }
    .cart-summary {
      position: relative;
      top: 0;
    }
  }
  @media (max-width: 576px) {
    .cart-item {
      grid-template-columns: 80px 1fr;
      gap: 15px;
    }
    .cart-item__image {
      width: 80px;
      height: 80px;
    }
    .cart-item__actions {
      grid-column: span 2;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding-top: 15px;
      border-top: 1px solid #eee;
      margin-top: 10px;
    }
  }
{%- endstyle -%}

<section class="cart-template" data-section-id="{{ section.id }}" data-cart-page>
  <div class="container" data-cart-page-container>
    {%- if cart.item_count > 0 -%}
      <div class="cart-header">
        <h1 class="cart-title">Your Cart</h1>
        <p class="cart-count" data-cart-page-count>{{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}</p>
      </div>
      
      <form action="{{ routes.cart_url }}" method="post" class="cart-form">
        <div class="cart-layout">
          <div class="cart-items" data-cart-page-items>
            {%- for item in cart.items -%}
              <div class="cart-item" data-cart-item data-line="{{ forloop.index }}" data-key="{{ item.key }}">
                <div class="cart-item__image">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title }}" width="120" height="120" loading="lazy">
                  {%- endif -%}
                </div>
                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <span class="cart-item__price">{{ item.price | money }}</span>
                </div>
                <div class="cart-item__actions">
                  <div class="cart-item__quantity">
                    <button type="button" class="cart-qty-btn" data-action="decrease" data-line="{{ forloop.index }}">−</button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="cart-qty-input" data-line="{{ forloop.index }}" aria-label="Quantity">
                    <button type="button" class="cart-qty-btn" data-action="increase" data-line="{{ forloop.index }}">+</button>
                  </div>
                  <span class="cart-item__total">{{ item.line_price | money }}</span>
                  <button type="button" class="cart-item__remove" data-line="{{ forloop.index }}">Remove</button>
                </div>
              </div>
            {%- endfor -%}
          </div>
          
          <div class="cart-summary" data-cart-page-summary>
            <h2 class="cart-summary__title">Order Summary</h2>
            
            {%- assign free_shipping_threshold = settings.free_shipping_threshold | default: 400 -%}
            {%- assign cart_total_cents = cart.total_price | divided_by: 100 -%}
            {%- assign remaining = free_shipping_threshold | minus: cart_total_cents -%}
            {%- assign progress = cart_total_cents | times: 100 | divided_by: free_shipping_threshold -%}
            {%- if progress > 100 %}{% assign progress = 100 %}{% endif -%}
            
            <div class="free-shipping-bar" data-cart-shipping-bar>
              {%- if remaining > 0 -%}
                <p>Add <strong>₹{{ remaining }}</strong> more for FREE shipping!</p>
              {%- else -%}
                <p>🎉 You've unlocked FREE shipping!</p>
              {%- endif -%}
              <div class="free-shipping-progress">
                <div class="free-shipping-progress__bar" style="width: {{ progress }}%"></div>
              </div>
            </div>
            
            <div class="cart-summary__row" data-cart-subtotal-row>
              <span class="cart-summary__label">Subtotal</span>
              <span class="cart-summary__value" data-cart-page-subtotal>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary__row" data-cart-shipping-row>
              <span class="cart-summary__label">Shipping</span>
              <span class="cart-summary__value {% if remaining <= 0 %}free{% endif %}" data-cart-page-shipping>
                {%- if remaining <= 0 -%}FREE{%- else -%}Calculated at checkout{%- endif -%}
              </span>
            </div>
            <div class="cart-summary__row total" data-cart-total-row>
              <span>Total</span>
              <span data-cart-page-total>{{ cart.total_price | money }}</span>
            </div>
            
            <div class="cart-note">
              <label for="cart-note">Order notes (optional)</label>
              <textarea id="cart-note" name="note" placeholder="Special instructions for your order">{{ cart.note }}</textarea>
            </div>
            
            <button type="submit" name="checkout" class="cart-checkout-btn">
              Proceed to Checkout
            </button>
            <a href="/collections/all" class="cart-continue">Continue Shopping</a>
            
            <div class="cart-trust">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
            </div>
          </div>
        </div>
      </form>
      
    {%- else -%}
      <div class="cart-empty" data-cart-empty>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added any products to your cart yet. Start shopping to discover our range of Ayurvedic wellness products.</p>
        <a href="/collections/all">Start Shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart Template",
  "tag": "section",
  "class": "section-cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Show order notes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_shipping_bar",
      "label": "Show free shipping progress",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Cart Template"
    }
  ]
}
{% endschema %}
