<script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer="defer"></script>
<script>
  (function() {
    document.querySelectorAll('select[data-default]').forEach(function(el) {
      if (typeof Shopify !== 'undefined' && Shopify.CountryProvinceSelector) { return; }
    });
    if (window.Shopify && Shopify.CountryProvinceSelector) {
      document.querySelectorAll('.addr-form').forEach(function(form, i) {
        var country = form.querySelector('select[name="address[country]"]');
        var province = form.querySelector('select[name="address[province]"]');
        if (!country || !province) return;
        country.id = country.id || ('country-' + i);
        province.id = province.id || ('province-' + i);
        new Shopify.CountryProvinceSelector(country.id, province.id, {
          hideElement: province.parentNode
        });
      });
    }

    var addToggle = document.querySelectorAll('[data-add-toggle]');
    var addForm = document.querySelector('[data-add-form]');
    var addCancel = document.querySelector('[data-add-cancel]');
    addToggle.forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!addForm) return;
        addForm.classList.add('is-active');
        addForm.scrollIntoView({behavior: 'smooth', block: 'start'});
      });
    });
    if (addCancel) addCancel.addEventListener('click', function() { addForm.classList.remove('is-active'); });

    document.querySelectorAll('[data-edit-toggle]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-edit-toggle');
        var panel = document.querySelector('[data-edit-form="' + id + '"]');
        if (panel) {
          panel.classList.toggle('is-active');
          if (panel.classList.contains('is-active')) panel.scrollIntoView({behavior: 'smooth', block: 'nearest'});
        }
      });
    });
    document.querySelectorAll('[data-edit-cancel]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-edit-cancel');
        var panel = document.querySelector('[data-edit-form="' + id + '"]');
        if (panel) panel.classList.remove('is-active');
      });
    });

    document.querySelectorAll('[data-confirm-message]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var msg = btn.getAttribute('data-confirm-message');
        if (window.confirm(msg)) {
          var formId = btn.getAttribute('data-form-id');
          var form = document.getElementById(formId);
          if (form) form.submit();
        }
      });
    });
  })();
</script>

