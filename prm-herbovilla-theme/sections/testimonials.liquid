{%- comment -%}
  Testimonials Section
{%- endcomment -%}

<section class="section testimonials {% if section.settings.alt_background %}section--alt{% endif %}">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.label != blank -%}
        <span class="section-header__label">{{ section.settings.label }}</span>
      {%- endif -%}
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="section-header__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>
    
    <div class="testimonials__carousel" data-carousel>
      <div class="testimonials__track" data-carousel-track>
        {%- for block in section.blocks -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-card__rating">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            
            <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
            
            <div class="testimonial-card__author">
              {%- if block.settings.image != blank -%}
                <div class="testimonial-card__avatar">
                  <img 
                    src="{{ block.settings.image | image_url: width: 96 }}"
                    alt="{{ block.settings.name | escape }}"
                    width="48"
                    height="48"
                    loading="lazy"
                  >
                </div>
              {%- else -%}
                <div class="testimonial-card__avatar">
                  {{ block.settings.name | slice: 0 }}
                </div>
              {%- endif -%}
              
              <div>
                <div class="testimonial-card__name">{{ block.settings.name }}</div>
                {%- if block.settings.location != blank -%}
                  <div class="testimonial-card__location">{{ block.settings.location }}</div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      
      <div class="products-carousel__nav">
        <button type="button" class="products-carousel__btn" data-carousel-prev aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button type="button" class="products-carousel__btn" data-carousel-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "testimonials-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "alt_background",
      "label": "Use Alternative Background",
      "default": true
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Customer Stories"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Real experiences from real people who have transformed their health with our Ayurvedic products."
    }
  ],
  "blocks": [
