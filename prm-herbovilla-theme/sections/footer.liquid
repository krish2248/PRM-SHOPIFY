{%- style -%}
  .footer {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: 80px;
  }
  .footer a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .footer a:hover {
    color: {{ section.settings.link_hover_color }};
  }
  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1.1fr 1.3fr;
    gap: 50px;
    padding-bottom: 50px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .footer-brand {
    max-width: 360px;
  }
  .footer-logo {
    max-width: 180px;
    height: auto;
    margin-bottom: 20px;
  }
  .footer-logo-text {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
  }
  .footer-description {
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 22px;
  }
  .footer-certifications {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .certification-badge {
    background: rgba(255,255,255,0.10);
    padding: 7px 12px;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.3px;
  }
  .footer-column h4 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 25px;
    position: relative;
    letter-spacing: 0.3px;
  }
  .footer-column h4::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 28px;
    height: 2px;
    background: var(--color-primary-light, #40916C);
  }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links li {
    margin-bottom: 11px;
  }
  .footer-links a {
    font-size: 0.93rem;
    opacity: 0.85;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    word-break: break-word;
  }
  .footer-links a:hover {
    opacity: 1;
  }
  .footer-links-icon {
    width: 16px;
    height: 16px;
    opacity: 0.8;
    flex-shrink: 0;
  }
  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
  }
  .footer-contact-icon {
    width: 18px;
    height: 18px;
    opacity: 0.9;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .footer-contact-text {
    font-size: 0.93rem;
    opacity: 0.88;
    line-height: 1.55;
    word-break: break-word;
  }
  a.footer-contact-text:hover {
    opacity: 1;
  }
  .footer-social {
    display: flex;
    gap: 10px;
    margin-top: 22px;
  }
  .footer-social a {
    width: 38px;
    height: 38px;
    background: rgba(255,255,255,0.10);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  .footer-social a:hover {
    background: var(--color-primary, #2D6A4F);
    transform: translateY(-3px);
  }
  .footer-social svg {
    width: 16px;
    height: 16px;
  }
  .footer-marketplaces {
    margin-top: 32px;
    padding: 22px 0 20px;
    border-top: 1px solid rgba(255,255,255,0.10);
    border-bottom: 1px solid rgba(255,255,255,0.10);
  }
  .footer-marketplaces__title {
    font-size: 0.82rem;
    font-weight: 600;
    opacity: 0.72;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .footer-marketplaces__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }
  .footer-marketplace {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 10px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.92rem;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }
  .footer-marketplace:hover {
    background: rgba(255,255,255,0.14);
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.28);
  }
  .footer-marketplace--tata     { color: #ff7685; }
  .footer-marketplace--amazon   { color: #fff; text-transform: lowercase; }
  .footer-marketplace--amazon span { color: #FF9900; }
  .footer-marketplace--flipkart { color: #7aaaf7; font-style: italic; }
  .footer-marketplace--meesho   { color: #ff78bd; }
  .footer-brandsites {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.85rem;
  }
  .footer-brandsite {
    opacity: 0.82;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .footer-brandsite:hover { opacity: 1; }
  .footer-brandsite strong {
    display: inline-block;
    margin-right: 6px;
  }
  @media (max-width: 640px) {
    .footer-marketplaces__grid { grid-template-columns: repeat(2, 1fr); }
  }
  .footer-bottom {
    padding: 26px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  .footer-copyright {
    font-size: 0.88rem;
    opacity: 0.72;
  }
  .footer-payments {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .footer-payments span {
    font-size: 0.82rem;
    opacity: 0.7;
  }
  .payment-icons {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .payment-icon {
    background: rgba(255,255,255,0.10);
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .footer-legal {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }
  .footer-legal a {
    font-size: 0.82rem;
    opacity: 0.72;
  }
  .footer-legal a:hover {
    opacity: 1;
  }

  @media (max-width: 992px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-brand {
      grid-column: span 2;
      max-width: 100%;
    }
  }
  @media (max-width: 576px) {
    .footer {
      padding-top: 56px;
    }
    .footer-main {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 36px;
    }
    .footer-brand {
      grid-column: span 1;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
    .footer-legal {
      justify-content: center;
      gap: 14px;
    }
    .footer-payments {
      justify-content: center;
    }
  }
{%- endstyle -%}

<footer class="footer" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="footer-main">
      <!-- Brand Column -->
      <div class="footer-brand">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 360 }}" alt="{{ shop.name }}" class="footer-logo" width="180" height="auto" loading="lazy">
        {%- elsif settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 360 }}" alt="{{ shop.name }}" class="footer-logo" width="180" height="auto" loading="lazy">
        {%- else -%}
          <div class="footer-logo-text">{{ shop.name }}</div>
        {%- endif -%}
        <p class="footer-description">{{ section.settings.description }}</p>

        <div class="footer-social">
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#1B4332"></polygon></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_linkedin != blank -%}
            <a href="{{ settings.social_linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
          {%- endif -%}
        </div>

        {%- if section.settings.show_certifications -%}
          <div class="footer-certifications" style="margin-top: 24px;">
            {%- for block in section.blocks -%}
              {%- if block.type == 'certification' -%}
                <span class="certification-badge" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if settings.marketplace_tata1mg != blank or settings.marketplace_amazon != blank or settings.marketplace_flipkart != blank or settings.marketplace_meesho != blank -%}
          <div class="footer-marketplaces">
            <div class="footer-marketplaces__title">Also shop us on</div>
            <div class="footer-marketplaces__grid">
              {%- if settings.marketplace_tata1mg != blank -%}
                <a href="{{ settings.marketplace_tata1mg }}" target="_blank" rel="noopener" class="footer-marketplace footer-marketplace--tata">Tata 1mg</a>
              {%- endif -%}
              {%- if settings.marketplace_amazon != blank -%}
                <a href="{{ settings.marketplace_amazon }}" target="_blank" rel="noopener" class="footer-marketplace footer-marketplace--amazon">amazon<span>.in</span></a>
              {%- endif -%}
              {%- if settings.marketplace_flipkart != blank -%}
                <a href="{{ settings.marketplace_flipkart }}" target="_blank" rel="noopener" class="footer-marketplace footer-marketplace--flipkart">Flipkart</a>
              {%- endif -%}
              {%- if settings.marketplace_meesho != blank -%}
                <a href="{{ settings.marketplace_meesho }}" target="_blank" rel="noopener" class="footer-marketplace footer-marketplace--meesho">Meesho</a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if settings.brand_prm_pharma_url != blank or settings.brand_herbovilla_url != blank -%}
          <div class="footer-brandsites">
            {%- if settings.brand_prm_pharma_url != blank -%}
              <a href="{{ settings.brand_prm_pharma_url }}" target="_blank" rel="noopener" class="footer-brandsite">
                <strong>PRM Pharmaceuticals</strong>&rsaquo;
              </a>
            {%- endif -%}
            {%- if settings.brand_herbovilla_url != blank -%}
              <a href="{{ settings.brand_herbovilla_url }}" target="_blank" rel="noopener" class="footer-brandsite">
                <strong>HerboVilla Store</strong>&rsaquo;
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Customer Service -->
      <div class="footer-column">
        <h4>{{ section.settings.col2_title | default: 'Customer Service' }}</h4>
        <ul class="footer-links">
          <li>
            <a href="mailto:contact@prmpharmaceuticals.com">
              <svg class="footer-links-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              contact@prmpharmaceuticals.com
            </a>
          </li>
          <li>
            <a href="tel:+912782448087">
              <svg class="footer-links-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              0278 244 8087
            </a>
          </li>
          {%- if settings.contact_phone != blank -%}
            <li>
              <a href="tel:{{ settings.contact_phone | replace: ' ', '' | replace: '-', '' }}">
                <svg class="footer-links-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {{ settings.contact_phone }}
              </a>
            </li>
          {%- endif -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'link_col2' -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-column">
        <h4>{{ section.settings.col3_title | default: 'Visit &amp; Connect' }}</h4>

        {%- if settings.contact_address != blank -%}
          <div class="footer-contact-item">
            <svg class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span class="footer-contact-text">{{ settings.contact_address }}</span>
          </div>
        {%- endif -%}

        <div class="footer-contact-item">
          <svg class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span class="footer-contact-text">
            <strong style="display:block; margin-bottom:2px;">Business Hours</strong>
            Mon – Sat: 9:30 AM – 6:30 PM<br>
            Sunday: Closed
          </span>
        </div>

        {%- if settings.contact_email != blank -%}
          <div class="footer-contact-item">
            <svg class="footer-contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href="mailto:{{ settings.contact_email }}" class="footer-contact-text">{{ settings.contact_email }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}
      </div>

      {%- if section.settings.show_payments -%}
        <div class="footer-payments">
          <span>We Accept:</span>
          <div class="payment-icons">
            <span class="payment-icon">UPI</span>
            <span class="payment-icon">Visa</span>
            <span class="payment-icon">MC</span>
            <span class="payment-icon">RuPay</span>
            <span class="payment-icon">COD</span>
          </div>
        </div>
      {%- endif -%}

      <div class="footer-legal">
        <a href="{{ section.settings.privacy_link | default: '/policies/privacy-policy' }}">Privacy Policy</a>
        <a href="{{ section.settings.terms_link | default: '/policies/terms-of-service' }}">Terms of Service</a>
        <a href="{{ section.settings.refund_link | default: '/policies/refund-policy' }}">Refund Policy</a>
        <a href="{{ section.settings.shipping_link | default: '/policies/shipping-policy' }}">Shipping Policy</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1B4332"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#74c69d"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "PRM HerboVilla is the Ayurvedic and herbal wellness division of PRM Pharmaceuticals — crafting authentic, GMP-certified botanical formulations that bring ancient wisdom to modern life."
    },
    {
      "type": "checkbox",
      "id": "show_certifications",
      "label": "Show certifications",
      "default": true
    },
    {
      "type": "text",
      "id": "col2_title",
      "label": "Customer service column title",
      "default": "Customer Service"
    },
    {
      "type": "text",
      "id": "col3_title",
      "label": "Contact column title",
      "default": "Visit & Connect"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Show payment methods",
      "default": true
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy policy link"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms of service link"
    },
    {
      "type": "url",
      "id": "refund_link",
      "label": "Refund policy link"
    },
    {
      "type": "url",
      "id": "shipping_link",
      "label": "Shipping policy link"
    }
  ],
  "blocks": [
    {
      "type": "certification",
      "name": "Certification",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "GMP Certified"
        }
      ]
    },
    {
      "type": "link_col2",
      "name": "Customer Service Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Contact Us"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "certification", "settings": { "text": "GMP Certified" } },
        { "type": "certification", "settings": { "text": "ISO 9001:2015" } },
        { "type": "certification", "settings": { "text": "AYUSH Approved" } },
        { "type": "certification", "settings": { "text": "FSSAI Licensed" } },
        { "type": "link_col2", "settings": { "text": "Contact Us", "link": "/pages/contact" } },
        { "type": "link_col2", "settings": { "text": "About Us", "link": "/pages/about-us" } },
        { "type": "link_col2", "settings": { "text": "FAQs", "link": "/pages/faq" } },
        { "type": "link_col2", "settings": { "text": "Track Order", "link": "/account" } },
        { "type": "link_col2", "settings": { "text": "Returns & Refunds", "link": "/policies/refund-policy" } },
        { "type": "link_col2", "settings": { "text": "Shipping Info", "link": "/policies/shipping-policy" } }
      ]
    }
  ]
}
{% endschema %}
