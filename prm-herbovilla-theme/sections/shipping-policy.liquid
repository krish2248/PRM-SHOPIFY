{%- comment -%}
  Shipping Policy Page Template
{%- endcomment -%}

<div class="policy-page">
  <section class="policy-hero">
    <div class="container">
      <h1 class="policy-hero__title">{{ page.title | default: 'Shipping Policy' }}</h1>
      <p class="policy-hero__subtitle">{{ section.settings.subtitle | default: 'Everything you need to know about our shipping and delivery' }}</p>
    </div>
  </section>

  <section class="policy-content section">
    <div class="container">
      <div class="policy-grid">
        <aside class="policy-sidebar">
          <nav class="policy-nav">
            <h3>Quick Links</h3>
            <ul>
              <li><a href="#delivery-areas">Delivery Areas</a></li>
              <li><a href="#shipping-charges">Shipping Charges</a></li>
              <li><a href="#delivery-time">Delivery Time</a></li>
              <li><a href="#tracking">Order Tracking</a></li>
              <li><a href="#cod">Cash on Delivery</a></li>
            </ul>
          </nav>
        </aside>

        <div class="policy-main">
          <div class="policy-highlight">
            <div class="policy-highlight__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 8h14M5 8a2 2 0 1 1 0-4h14a2 2 0 1 1 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8"/>
                <path d="m9 14 2 2 4-4"/>
              </svg>
            </div>
            <div class="policy-highlight__content">
              <h3>Free Shipping on Orders Above ₹400</h3>
              <p>Enjoy free delivery across India when you spend ₹400 or more</p>
            </div>
          </div>

          <div class="policy-section" id="delivery-areas">
            <h2>Delivery Areas</h2>
            <p>We currently deliver to all serviceable pin codes across India. Our products are shipped from our facility in Bhavnagar, Gujarat to your doorstep via trusted courier partners.</p>
            
            <div class="policy-info-box">
              <h4>Serviceable Locations</h4>
              <ul>
                <li>All major cities and metros</li>
                <li>Tier 2 and Tier 3 cities</li>
                <li>Most rural areas with courier access</li>
              </ul>
              <p class="policy-note">Note: Some remote areas may have limited courier availability. Enter your pin code at checkout to verify delivery to your location.</p>
            </div>
          </div>

          <div class="policy-section" id="shipping-charges">
            <h2>Shipping Charges</h2>
            <table class="policy-table">
              <thead>
                <tr>
                  <th>Order Value</th>
                  <th>Shipping Charge</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Above ₹400</td>
                  <td><strong>FREE</strong></td>
                </tr>
                <tr>
                  <td>Below ₹400</td>
                  <td>₹50 flat rate</td>
                </tr>
              </tbody>
            </table>
            <p class="policy-note">Shipping charges are calculated at checkout based on your order total before applying any discounts.</p>
          </div>

          <div class="policy-section" id="delivery-time">
            <h2>Delivery Time</h2>
            <p>We process orders within 1-2 business days. Once shipped, delivery times vary based on your location:</p>
            
            <table class="policy-table">
              <thead>
                <tr>
                  <th>Location</th>
                  <th>Estimated Delivery</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Metro Cities (Mumbai, Delhi, Bangalore, etc.)</td>
                  <td>3-5 business days</td>
                </tr>
                <tr>
                  <td>Tier 2 Cities</td>
                  <td>5-7 business days</td>
                </tr>
                <tr>
                  <td>Tier 3 & Rural Areas</td>
                  <td>7-10 business days</td>
                </tr>
                <tr>
                  <td>Remote/Hilly Areas</td>
                  <td>10-14 business days</td>
                </tr>
              </tbody>
            </table>

            <div class="policy-info-box policy-info-box--warning">
              <h4>Please Note</h4>
              <ul>
                <li>Delivery times are estimates and may vary due to unforeseen circumstances</li>
                <li>Delays may occur during festivals, sales, or extreme weather conditions</li>
                <li>Business days exclude Sundays and public holidays</li>
              </ul>
            </div>
          </div>

          <div class="policy-section" id="tracking">
            <h2>Order Tracking</h2>
            <p>Stay updated on your order status with our tracking system:</p>
            <ol class="policy-steps">
              <li>
                <span class="step-number">1</span>
                <div>
                  <h4>Order Confirmation</h4>
                  <p>You'll receive an email and SMS confirming your order</p>
                </div>
              </li>
              <li>
                <span class="step-number">2</span>
                <div>
                  <h4>Shipment Notification</h4>
                  <p>Once shipped, you'll receive tracking details via email and SMS</p>
                </div>
              </li>
              <li>
                <span class="step-number">3</span>
                <div>
                  <h4>Track Online</h4>
                  <p>Use the tracking link or log into your account to check status</p>
                </div>
              </li>
              <li>
                <span class="step-number">4</span>
                <div>
                  <h4>Delivery</h4>
                  <p>Your order will be delivered to your doorstep</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="policy-section" id="cod">
            <h2>Cash on Delivery (COD)</h2>
            <p>We offer Cash on Delivery for your convenience:</p>
            <ul>
              <li>COD is available for orders up to ₹5,000</li>
              <li>No additional charges for COD orders</li>
              <li>Please keep exact change ready for the delivery person</li>
              <li>COD may not be available for some remote pin codes</li>
            </ul>

            <div class="policy-info-box">
              <h4>COD Verification</h4>
              <p>For first-time COD orders, our team may call to verify your details. This helps us ensure smooth delivery and prevent fraud.</p>
            </div>
          </div>

          <div class="policy-section">
            <h2>Contact Us</h2>
            <p>For any shipping-related queries, please reach out to us:</p>
            <div class="policy-contact">
              <p><strong>Email:</strong> contact@prmpharmaceuticals.com</p>
              <p><strong>Phone:</strong> +91-9227928075</p>
              <p><strong>Hours:</strong> Monday - Saturday, 10:00 AM - 6:00 PM IST</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .policy-page {
    --policy-spacing: 2rem;
  }

  .policy-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e4d3a 100%);
    color: var(--color-white);
    padding: 3rem 0;
    text-align: center;
  }

  .policy-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .policy-hero__subtitle {
    opacity: 0.9;
    font-size: 1.0625rem;
  }

  .policy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .policy-grid {
      grid-template-columns: 240px 1fr;
    }
  }

  .policy-sidebar {
    position: sticky;
    top: 120px;
    align-self: start;
  }

  @media (max-width: 1023px) {
    .policy-sidebar {
      position: static;
    }
  }

  .policy-nav {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .policy-nav h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .policy-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .policy-nav a {
    display: block;
    padding: 0.5rem 0;
    color: var(--color-text-light);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }

  .policy-nav a:hover {
    color: var(--color-primary);
  }

  .policy-main {
    max-width: 800px;
  }

  .policy-highlight {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, #1e4d3a 100%);
    color: var(--color-white);
    padding: 1.5rem 2rem;
    border-radius: var(--radius-lg);
    margin-bottom: 3rem;
  }

  .policy-highlight__icon {
    width: 60px;
    height: 60px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .policy-highlight__icon svg {
    width: 28px;
    height: 28px;
  }

  .policy-highlight h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .policy-highlight p {
    opacity: 0.9;
    font-size: 0.9375rem;
    margin: 0;
  }

  .policy-section {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .policy-section:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .policy-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .policy-section p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .policy-section ul,
  .policy-section ol {
    color: var(--color-text-light);
    line-height: 1.8;
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .policy-section li {
    margin-bottom: 0.5rem;
  }

  .policy-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }

  .policy-table th,
  .policy-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .policy-table th {
    background: var(--color-background-alt);
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.875rem;
  }

  .policy-table td {
    color: var(--color-text-light);
  }

  .policy-table tr:last-child td {
    border-bottom: none;
  }

  .policy-info-box {
    background: var(--color-background-alt);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .policy-info-box--warning {
    background: #fff8e6;
    border-left: 4px solid #f0a500;
  }

  .policy-info-box h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .policy-info-box ul {
    margin: 0;
    padding-left: 1.25rem;
  }

  .policy-info-box p {
    margin: 0;
  }

  .policy-note {
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-text-light);
  }

  .policy-steps {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }

  .policy-steps li {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .policy-steps li:last-child {
    border-bottom: none;
  }

  .step-number {
    width: 32px;
    height: 32px;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .policy-steps h4 {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .policy-steps p {
    font-size: 0.9375rem;
    margin: 0;
  }

  .policy-contact {
    background: var(--color-white);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .policy-contact p {
    margin-bottom: 0.5rem;
  }

  .policy-contact p:last-child {
    margin-bottom: 0;
  }
</style>

{% schema %}
{
  "name": "Shipping Policy",
  "tag": "section",
  "class": "section-shipping-policy",
  "settings": [
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Page Subtitle",
      "default": "Everything you need to know about our shipping and delivery"
    }
  ],
  "presets": [
    {
      "name": "Shipping Policy"
    }
  ]
}
{% endschema %}
