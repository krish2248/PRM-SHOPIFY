        { "type": "ingredient", "settings": { "herb_icon": "tulsi", "title": "Tulsi", "text": "Natural adaptogen & antioxidant", "benefits": "Supports respiratory health, reduces inflammation, fights infections, balances blood sugar, and promotes mental clarity." } },
        { "type": "ingredient", "settings": { "herb_icon": "amla", "title": "Amla", "text": "Rich in Vitamin C & rejuvenating", "benefits": "Contains 20x more Vitamin C than oranges, promotes hair growth, improves skin health, and supports digestive function." } },
