{%- comment -%}
  Ingredients Section - Large categorized herb directory
  Shows the full library of Ayurvedic herbs, resins & oils used across
  every HerboVilla formulation. Pulled directly from the product PPTs.
{%- endcomment -%}

{%- style -%}
  .ingredients-section-wrapper {
    padding: 64px 0 72px;
    background: {{ section.settings.bg_color | default: '#FDF8F0' }};
  }
  .ingredients-categories {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 36px;
  }
  .ingredients-card {
    background: #fff;
    border-radius: 14px;
    padding: 24px 22px 26px;
    box-shadow: 0 2px 14px rgba(45, 106, 79, 0.06);
    border: 1px solid rgba(45, 106, 79, 0.07);
  }
  .ingredients-card__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(45, 106, 79, 0.1);
  }
  .ingredients-card__icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(45, 106, 79, 0.1);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ingredients-card__icon svg {
    width: 18px;
    height: 18px;
  }
  .ingredients-card__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.2;
  }
  .ingredients-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
    column-gap: 18px;
  }
  .ingredients-card__list li {
    position: relative;
    padding: 3px 0 3px 15px;
    font-size: 0.82rem;
    color: var(--color-text);
    line-height: 1.55;
    break-inside: avoid;
  }
  .ingredients-card__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.55;
  }
  .ingredients-card__list li strong {
    color: var(--color-text);
    font-weight: 400;
  }
  .ingredients-sourcing {
    margin-top: 32px;
    padding: 22px 26px;
    background: rgba(45, 106, 79, 0.06);
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    text-align: center;
    color: var(--color-text);
    font-size: 0.88rem;
  }
  .ingredients-sourcing svg {
    width: 20px;
    height: 20px;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  @media (max-width: 1024px) {
    .ingredients-categories {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .ingredients-section-wrapper {
      padding: 48px 0 56px;
    }
    .ingredients-categories {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .ingredients-card {
      padding: 20px 18px 22px;
    }
    .ingredients-card__list {
      columns: 2;
      column-gap: 14px;
    }
  }
{%- endstyle -%}

