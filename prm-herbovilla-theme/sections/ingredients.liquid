{% schema %}
{
  "name": "Ingredients",
  "tag": "section",
  "class": "ingredients-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDF8F0"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Pure Ingredients"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Powered by Nature's Finest"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Every HerboVilla formulation draws from a library of 80+ authentic Ayurvedic herbs, resins and oils."
    }
  ],
  "presets": [
    {
      "name": "Ingredients"
    }
  ]
}
{% endschema %}
