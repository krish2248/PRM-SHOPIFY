      "max": 24,
      "step": 3,
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tag filters",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Blog Template"
    }
  ]
}
{% endschema %}
