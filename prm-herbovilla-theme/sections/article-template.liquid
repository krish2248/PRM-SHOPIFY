{%- style -%}
  .article-template {
    padding: 40px 0 80px;
  }
  .article-header {
    max-width: 800px;
    margin: 0 auto 40px;
    text-align: center;
  }
  .article-breadcrumbs {
    margin-bottom: 25px;
  }
  .article-breadcrumbs a {
    color: var(--color-text-light);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .article-breadcrumbs a:hover {
    color: var(--color-primary);
  }
  .article-breadcrumbs span {
    color: var(--color-text-light);
    margin: 0 8px;
  }
  .article-meta {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
    color: var(--color-text-light);
    font-size: 0.9rem;
    flex-wrap: wrap;
  }
  .article-meta__item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .article-meta__item svg {
    width: 16px;
    height: 16px;
  }
  .article-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .article-tags {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .article-tag {
    padding: 6px 14px;
    background: rgba(45, 106, 79, 0.1);
    color: var(--color-primary);
    border-radius: 15px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .article-tag:hover {
    background: var(--color-primary);
    color: #fff;
  }
  .article-featured-image {
    max-width: 1000px;
    margin: 0 auto 50px;
    border-radius: 20px;
    overflow: hidden;
  }
  .article-featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .article-content {
    max-width: 750px;
    margin: 0 auto;
  }
  .article-body {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--color-text);
  }
  .article-body h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin: 40px 0 20px;
    color: var(--color-text);
  }
  .article-body h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    margin: 30px 0 15px;
  }
  .article-body p {
    margin-bottom: 20px;
  }
  .article-body ul,
  .article-body ol {
    margin: 20px 0;
    padding-left: 25px;
  }
  .article-body li {
    margin-bottom: 10px;
  }
  .article-body blockquote {
    background: #f8fdf8;
    border-left: 4px solid var(--color-primary);
    padding: 25px 30px;
    margin: 30px 0;
    border-radius: 0 15px 15px 0;
    font-style: italic;
    font-size: 1.15rem;
  }
  .article-body img {
    max-width: 100%;
    height: auto;
    border-radius: 15px;
    margin: 30px 0;
  }
  .article-body a {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .article-share {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid #eee;
  }
  .article-share__label {
    font-weight: 600;
    color: var(--color-text);
  }
  .article-share__links {
    display: flex;
    gap: 10px;
  }
  .article-share__link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .article-share__link:hover {
    background: var(--color-primary);
    color: #fff;
  }
  .article-share__link svg {
    width: 18px;
    height: 18px;
  }
  .article-author {
    background: #f8f8f8;
    border-radius: 20px;
    padding: 30px;
    margin-top: 50px;
    display: flex;
    gap: 25px;
    align-items: center;
  }
  .article-author__avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .article-author__name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: 5px;
  }
  .article-author__bio {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .article-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 60px;
    padding-top: 40px;
    border-top: 1px solid #eee;
  }
  .article-nav__item {
    padding: 25px;
    background: #f8f8f8;
    border-radius: 15px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .article-nav__item:hover {
    background: #f0f0f0;
  }
  .article-nav__item--next {
    text-align: right;
  }
  .article-nav__label {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .article-nav__item--next .article-nav__label {
    justify-content: flex-end;
  }
  .article-nav__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text);
  }
  .article-comments {
    margin-top: 60px;
    padding-top: 40px;
    border-top: 1px solid #eee;
  }
  .article-comments h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: 30px;
  }
  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }
    .article-author {
      flex-direction: column;
      text-align: center;
    }
    .article-nav {
      grid-template-columns: 1fr;
    }
    .article-nav__item--next {
      text-align: left;
    }
    .article-nav__item--next .article-nav__label {
      justify-content: flex-start;
    }
  }
{%- endstyle -%}

<article class="article-template" data-section-id="{{ section.id }}">
  <div class="container">
    <header class="article-header">
      <nav class="article-breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="{{ blog.url }}">{{ blog.title }}</a>
        <span>/</span>
        <span>{{ article.title | truncate: 30 }}</span>
      </nav>
      
      <div class="article-meta">
        <span class="article-meta__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          {{ article.published_at | date: '%B %d, %Y' }}
        </span>
        {%- if article.author -%}
          <span class="article-meta__item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            {{ article.author }}
          </span>
        {%- endif -%}
        <span class="article-meta__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read
        </span>
      </div>
      
      <h1 class="article-title">{{ article.title }}</h1>
      
      {%- if article.tags.size > 0 -%}
        <div class="article-tags">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-tag">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </header>
    
    {%- if article.image -%}
      <div class="article-featured-image">
        <img
          src="{{ article.image | image_url: width: 2000 }}"
          alt="{{ article.image.alt | default: article.title }}"
          width="1000"
          height="500"
          loading="eager"
        >
      </div>
    {%- endif -%}
    
    <div class="article-content">
      <div class="article-body rte">
        {{ article.content }}
      </div>
      
      <div class="article-share">
        <span class="article-share__label">Share:</span>
        <div class="article-share__links">
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="article-share__link" aria-label="Share on Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="article-share__link" aria-label="Share on Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
          </a>
          <a href="https://wa.me/?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="article-share__link" aria-label="Share on WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="mailto:?subject={{ article.title | url_encode }}&body={{ shop.url }}{{ article.url }}" class="article-share__link" aria-label="Share via Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </a>
        </div>
      </div>
      
      {%- if section.settings.show_author -%}
        <div class="article-author">
          <div class="article-author__avatar">
            {{ article.author | slice: 0 | upcase }}
          </div>
          <div>
            <h4 class="article-author__name">{{ article.author }}</h4>
            <p class="article-author__bio">{{ section.settings.author_bio | default: 'Health and wellness writer at PRM HerboVilla, passionate about sharing Ayurvedic knowledge and natural living tips.' }}</p>
          </div>
        </div>
      {%- endif -%}
      
      <nav class="article-nav">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article.url }}" class="article-nav__item article-nav__item--prev">
            <div class="article-nav__label">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
              Previous Article
            </div>
            <div class="article-nav__title">{{ blog.previous_article.title | truncate: 50 }}</div>
          </a>
        {%- else -%}
          <div></div>
        {%- endif -%}
        
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article.url }}" class="article-nav__item article-nav__item--next">
            <div class="article-nav__label">
              Next Article
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </div>
            <div class="article-nav__title">{{ blog.next_article.title | truncate: 50 }}</div>
          </a>
        {%- endif -%}
      </nav>
      
      {%- if blog.comments_enabled? -%}
        <div class="article-comments" id="comments">
          <h3>Comments ({{ article.comments_count }})</h3>
          {%- paginate article.comments by 10 -%}
            {%- for comment in article.comments -%}
              <div class="comment">
                <strong>{{ comment.author }}</strong>
                <time datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">{{ comment.created_at | date: '%B %d, %Y' }}</time>
                <p>{{ comment.content }}</p>
              </div>
            {%- endfor -%}
          {%- endpaginate -%}
          
          {%- form 'new_comment', article -%}
            <h4>Leave a comment</h4>
            <input type="text" name="comment[author]" placeholder="Name" required>
            <input type="email" name="comment[email]" placeholder="Email" required>
            <textarea name="comment[body]" placeholder="Comment" required></textarea>
            <button type="submit">Post Comment</button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Article Template",
  "tag": "section",
  "class": "section-article",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author bio",
      "default": true
    },
    {
      "type": "textarea",
      "id": "author_bio",
      "label": "Author bio",
      "default": "Health and wellness writer at PRM HerboVilla, passionate about sharing Ayurvedic knowledge and natural living tips."
    },
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "Show share buttons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Article Template"
    }
  ]
}
{% endschema %}
